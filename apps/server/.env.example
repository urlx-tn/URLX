# Server Worker bindings
# These values are read by packages/infra/alchemy.run.ts and bound to the Hono Worker.

# Required: origin of the web app, used by the server Worker CORS policy.
CORS_ORIGIN=http://localhost:4321

# Optional: public origin used when building short links.
# Defaults to http://localhost:3000 if not set.
SHORT_URL_BASE=http://localhost:3000
