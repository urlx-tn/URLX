---
import logo from "../assets/logo.png";

const year = new Date().getFullYear();

const productLinks = [
	{ label: "URL Shortener", href: "/tools/url-shortener" },
	{ label: "QR Code Generator", href: "/tools/qr-code-generator" },
	{ label: "URL Cleaner", href: "/tools/url-cleaner" },
	{ label: "Link in Bio", href: "/tools/link-in-bio" },
	{ label: "Search pages", href: "/tools/link-in-bio/search" },
	{ label: "GitHub", href: "https://github.com/urlx-tn/URLX", external: true },
];

const legalLinks = [
	{ label: "Privacy", href: "/legal/privacy" },
	{ label: "Terms", href: "/legal/terms" },
];
---

<footer class="border-t border-hair bg-surface">
	<div class="mx-auto w-full max-w-[980px] px-6 py-14 sm:py-16">
		<div
			class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.5fr_0.6fr_0.6fr] lg:gap-16"
		>
			<div>
				<a href="/" class="inline-flex items-center no-underline" aria-label="URLX home">
					<img
						src={logo.src}
						alt="URLX"
						width="1033"
						height="274"
						class="h-[28px] w-auto"
						loading="lazy"
					/>
				</a>
				<p class="mt-4 text-[15px] leading-7 text-ink-2">
					Free, open-source tools for shortening, cleaning, and sharing URLs.
					No account required.
				</p>
			</div>

			<div class="lg:pl-8">
				<h3 class="text-[13px] font-semibold uppercase tracking-[0.04em] text-ink">
					Product
				</h3>
				<ul class="mt-4 space-y-2.5">
					{
						productLinks.map((link) => (
							<li>
								<a
									href={link.href}
									target={link.external ? "_blank" : undefined}
									rel={link.external ? "noopener noreferrer" : undefined}
									class="inline-flex items-center gap-1.5 text-[15px] text-ink-2 underline-offset-2 transition-colors hover:text-ink hover:underline"
								>
									{link.label}
									{link.external && (
										<svg
											class="h-3 w-3 text-ink-2/70"
											viewBox="0 0 16 16"
											fill="none"
											stroke="currentColor"
											stroke-width="1.5"
											stroke-linecap="round"
											aria-hidden="true"
										>
											<path d="M6 4h6v6M12 4 6 10" />
										</svg>
									)}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<div class="lg:pl-8">
				<h3 class="text-[13px] font-semibold uppercase tracking-[0.04em] text-ink">
					Legal
				</h3>
				<ul class="mt-4 space-y-2.5">
					{
						legalLinks.map((link) => (
							<li>
								<a
									href={link.href}
									class="text-[15px] text-ink-2 underline-offset-2 transition-colors hover:text-ink hover:underline"
								>
									{link.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>
		</div>

		<div
			class="mt-10 flex flex-col items-start justify-between gap-4 border-t border-hair pt-6 sm:flex-row sm:items-center"
		>
			<p class="text-[13px] text-ink-2">
				© {year} URLX. Built by
				<a
					href="https://v1.chames.dhibi.tn"
					class="text-ink-2 underline-offset-2 transition-colors hover:text-ink hover:underline"
					target="_blank"
					rel="noopener noreferrer">Chames Eddine Dhibi</a
				>
				&amp;
				<a
					href="https://youssef.tn"
					class="text-ink-2 underline-offset-2 transition-colors hover:text-ink hover:underline"
					target="_blank"
					rel="noopener noreferrer">Youssef Dhibi</a
				>
				· MIT Licensed
			</p>
			<a
				href="https://github.com/urlx-tn/URLX"
				class="inline-flex items-center gap-2 text-[13px] text-ink-2 underline-offset-2 transition-colors hover:text-ink hover:underline"
				target="_blank"
				rel="noopener noreferrer"
			>
				<svg
					class="h-4 w-4"
					viewBox="0 0 24 24"
					fill="currentColor"
					aria-hidden="true"
				>
					<path
						fill-rule="evenodd"
						clip-rule="evenodd"
						d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"
					/>
				</svg>
				View on GitHub
			</a>
		</div>
	</div>
</footer>
