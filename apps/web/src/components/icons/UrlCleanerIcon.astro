---
import urlCleanerIcon from "../../assets/icons/url-cleaner.png";

interface Props {
	class?: string;
}

const { class: className = "h-auto w-40 max-w-full object-contain" } =
	Astro.props;
---

<img
	src={urlCleanerIcon.src}
	width={urlCleanerIcon.width}
	height={urlCleanerIcon.height}
	alt=""
	class={className}
	aria-hidden="true"
	decoding="async"
/>
