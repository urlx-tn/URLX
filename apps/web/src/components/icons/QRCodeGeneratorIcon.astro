---
import qrCodeGeneratorIcon from "../../assets/icons/qr-code-generator.png";

interface Props {
	class?: string;
}

const { class: className = "h-24 w-auto max-w-full object-contain" } =
	Astro.props;
---

<img
	src={qrCodeGeneratorIcon.src}
	width={qrCodeGeneratorIcon.width}
	height={qrCodeGeneratorIcon.height}
	alt=""
	class={className}
	aria-hidden="true"
	decoding="async"
/>
