---
import urlToMarkdownIcon from "../../assets/icons/url-to-markdown.png";

interface Props {
	class?: string;
}

const { class: className = "h-auto w-40 max-w-full object-contain" } =
	Astro.props;
---

<img
	src={urlToMarkdownIcon.src}
	width={urlToMarkdownIcon.width}
	height={urlToMarkdownIcon.height}
	alt=""
	class={className}
	aria-hidden="true"
	decoding="async"
/>
