---
import urlShortenerIcon from "../../assets/icons/url-shortener.png";

interface Props {
	class?: string;
}

const { class: className = "h-auto w-40 max-w-full object-contain" } =
	Astro.props;
---

<img
	src={urlShortenerIcon.src}
	width={urlShortenerIcon.width}
	height={urlShortenerIcon.height}
	alt=""
	class={className}
	aria-hidden="true"
	decoding="async"
/>
