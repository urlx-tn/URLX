---
import urlMetadataIcon from "../../assets/icons/url-metadata.png";

interface Props {
	class?: string;
}

const { class: className = "h-24 w-auto max-w-full object-contain" } =
	Astro.props;
---

<img
	src={urlMetadataIcon.src}
	width={urlMetadataIcon.width}
	height={urlMetadataIcon.height}
	alt=""
	class={className}
	aria-hidden="true"
	decoding="async"
/>
