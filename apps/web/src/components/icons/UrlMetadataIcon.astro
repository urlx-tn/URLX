	xmlns="http://www.w3.org/2000/svg"
	class={className}
	aria-hidden="true"
>
	<rect x="18" y="18" width="124" height="84" rx="14" fill="#F5F5F7" />
	<rect x="18" y="18" width="124" height="84" rx="14" stroke="#D9D9E0" stroke-width="2" />
	<rect x="32" y="34" width="96" height="16" rx="8" fill="#1D1D1F" />
	<rect x="32" y="62" width="44" height="26" rx="8" fill="#0A84FF" />
	<rect x="86" y="64" width="42" height="6" rx="3" fill="#6E6E73" />
	<rect x="86" y="77" width="30" height="6" rx="3" fill="#A1A1A6" />
	<circle cx="124" cy="38" r="18" fill="#34C759" />
