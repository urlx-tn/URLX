---
import urlToHtmlIcon from "../../assets/icons/url-to-html.png";

interface Props {
	class?: string;
}

const { class: className = "h-auto w-40 max-w-full object-contain" } =
	Astro.props;
---

<img
	src={urlToHtmlIcon.src}
	width={urlToHtmlIcon.width}
	height={urlToHtmlIcon.height}
	alt=""
	class={className}
	aria-hidden="true"
	decoding="async"
/>
