---
interface Props {
	format: "html" | "markdown";
	heading: string;
	intro: string;
	resultLabel: string;
	downloadLabel: string;
	privacyText: string;
	placeholder?: string;
}

const {
	format,
	heading,
	intro,
	resultLabel,
	downloadLabel,
	privacyText,
	placeholder = "example.com/article",
} = Astro.props;
---

<section
	data-page-root="conversion-tool"
	data-format={format}
	class="flex flex-1 bg-white"
>
	<div class="mx-auto w-full max-w-[980px] px-6 pt-16 pb-24 sm:pb-28">
		<header class="text-center">
			<h1
				class="text-[40px] font-semibold leading-[1.05] tracking-[-0.02em] text-ink sm:text-[56px]"
			>
				{heading}
			</h1>
			<p
				class="mx-auto mt-5 max-w-[42ch] text-[19px] leading-7 text-ink-2 sm:text-[21px]"
			>
				{intro}
			</p>
		</header>

		<div class="mx-auto mt-10 max-w-[800px]">
			<div class="mx-auto max-w-[560px]">
				<form class="flex flex-col gap-3" data-conversion="form" novalidate>
					<div class="flex flex-col gap-3 sm:flex-row">
						<label class="sr-only" for={`${format}-url`}>URL to convert</label>
						<div class="relative flex-1" data-conversion="input-wrap">
							<div
								class="field flex items-center gap-2 overflow-hidden pl-4"
								data-conversion="input-shell"
							>
								<span
									class="shrink-0 select-none text-[15px] text-ink-2"
									aria-hidden="true"
								>
									https://
								</span>
								<input
									id={`${format}-url`}
									name="url"
									type="url"
									inputmode="url"
									autocomplete="off"
									spellcheck="false"
									autocapitalize="off"
									placeholder={placeholder}
									class="min-w-0 flex-1 bg-transparent text-[15px] text-ink placeholder:text-ink-2/70 focus:outline-none"
									data-conversion="url"
									role="combobox"
									aria-invalid="false"
									aria-expanded="false"
									aria-autocomplete="list"
									aria-haspopup="listbox"
									aria-controls={`${format}-history`}
									aria-describedby={`${format}-error ${format}-privacy`}
								/>
							</div>
							<ul
								id={`${format}-history`}
								class="absolute inset-x-0 top-full z-30 mt-2 max-h-[280px] overflow-auto rounded-xl border border-hair bg-white py-1 shadow-[0_8px_30px_rgb(0_0_0/0.08)]"
								role="listbox"
								aria-label="Recent URLs"
								data-conversion="history"
								hidden
							>
							</ul>
						</div>
						<button
							type="submit"
							class="btn w-full sm:w-auto sm:min-w-[148px]"
							data-conversion="submit"
						>
							<span
								class="spinner shrink-0"
								aria-hidden="true"
								data-conversion="spinner"
								hidden
							>
							</span>
							<span data-conversion="submit-label">Convert</span>
						</button>
					</div>
					<div
						class="flex flex-col gap-2 text-[13px] leading-5 text-ink-2 sm:flex-row sm:items-center sm:justify-between"
					>
						<label class="inline-flex items-center gap-2">
							<input
								type="checkbox"
								class="h-4 w-4 accent-accent"
								data-conversion="remember-history"
							/>
							<span>Remember recent URLs on this device</span>
						</label>
						<button
							type="button"
							class="self-start text-link underline-offset-2 hover:underline sm:self-auto"
							data-conversion="clear-history"
							hidden
						>
							Clear recent URLs
						</button>
					</div>
				</form>

				<p
					id={`${format}-error`}
					class="mt-3 text-[14px] leading-5 text-[#d70015]"
					role="alert"
					aria-live="assertive"
					data-conversion="error"
					hidden
				>
				</p>
				<p id={`${format}-privacy`} class="mt-3 text-[13px] leading-5 text-ink-2">
					{privacyText}
				</p>
			</div>

			<section
				class="surface reveal mt-8 p-5 sm:p-7"
				data-conversion="result"
				aria-labelledby={`${format}-result-title`}
				aria-live="polite"
				hidden
			>
				<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
					<div class="min-w-0">
						<h2
							id={`${format}-result-title`}
							class="text-[18px] font-semibold text-ink"
						>
							{resultLabel}
						</h2>
						<a
							href="#"
							target="_blank"
							rel="noopener noreferrer"
							class="mt-1 block truncate text-[13px] text-link underline-offset-2 hover:underline"
							data-conversion="source"
						>
						</a>
					</div>
					<div class="flex shrink-0 gap-2">
						<button
							type="button"
							class="btn-secondary inline-flex h-10 items-center justify-center rounded-xl border px-4 text-[14px]"
							data-conversion="copy"
						>
							<span class="copy-label" data-conversion="copy-label">Copy</span>
						</button>
						<button
							type="button"
							class="btn-secondary inline-flex h-10 items-center justify-center rounded-xl border px-4 text-[14px]"
							data-conversion="download"
						>
							{downloadLabel}
						</button>
					</div>
				</div>

				<label class="sr-only" for={`${format}-output`}>Generated {resultLabel}</label>
				<textarea
					id={`${format}-output`}
					readonly
					spellcheck="false"
					class="mt-5 min-h-[360px] w-full resize-y rounded-xl border border-hair bg-white p-4 font-mono text-[13px] leading-6 text-ink outline-none focus:border-accent focus:ring-4 focus:ring-accent/20"
					data-conversion="output"
				>
				</textarea>

				<div class="mt-4 flex items-center justify-between gap-4">
					<p class="text-[13px] text-ink-2" data-conversion="meta"></p>
					<button
						type="button"
						class="text-[14px] text-link underline-offset-2 hover:underline"
						data-conversion="reset"
					>
						Convert another URL
					</button>
				</div>
			</section>
		</div>
	</div>
</section>

<script>
	import { copyToClipboard } from "../lib/copy-to-clipboard";
	import { convertUrl, type ConversionFormat } from "../lib/conversion";
	import { friendlyErrorMessage } from "../lib/form-errors";
	import { registerPageScript } from "../lib/page-script";
	import {
		addRecentUrl,
		clearRecentUrls,
		getRecentUrls,
		isUrlHistoryEnabled,
		removeRecentUrl,
		setUrlHistoryEnabled,
	} from "../lib/url-history";
	import {
		isValidUrl,
		normalizeUserUrlInput,
		stripScheme,
	} from "../lib/url-tools";

	type State =
		| { status: "idle" }
		| { status: "submitting" }
		| { status: "success"; sourceUrl: string; content: string }
		| { status: "error"; message: string };

	registerPageScript<HTMLElement>(
		'[data-page-root="conversion-tool"]',
		(root, signal) => {
			const selectRequired = <T extends Element>(selector: string): T => {
				const element = root.querySelector<T>(selector);
				if (!element) throw new Error(`Missing required element: ${selector}`);
				return element;
			};

			const format = root.dataset.format as ConversionFormat;
			const form = selectRequired<HTMLFormElement>('[data-conversion="form"]');
			const input = selectRequired<HTMLInputElement>('[data-conversion="url"]');
			const inputShell = selectRequired<HTMLElement>(
				'[data-conversion="input-shell"]',
			);
			const inputWrap = selectRequired<HTMLElement>(
				'[data-conversion="input-wrap"]',
			);
			const historyList = selectRequired<HTMLUListElement>(
				'[data-conversion="history"]',
			);
			const rememberHistory = selectRequired<HTMLInputElement>(
				'[data-conversion="remember-history"]',
			);
			const clearHistoryButton = selectRequired<HTMLButtonElement>(
				'[data-conversion="clear-history"]',
			);
			const submit = selectRequired<HTMLButtonElement>(
				'[data-conversion="submit"]',
			);
			const submitLabel = selectRequired<HTMLElement>(
				'[data-conversion="submit-label"]',
			);
			const spinner = selectRequired<HTMLElement>(
				'[data-conversion="spinner"]',
			);
			const errorElement = selectRequired<HTMLElement>(
				'[data-conversion="error"]',
			);
			const result = selectRequired<HTMLElement>(
				'[data-conversion="result"]',
			);
			const source = selectRequired<HTMLAnchorElement>(
				'[data-conversion="source"]',
			);
			const output = selectRequired<HTMLTextAreaElement>(
				'[data-conversion="output"]',
			);
			const meta = selectRequired<HTMLElement>('[data-conversion="meta"]');
			const copy = selectRequired<HTMLButtonElement>(
				'[data-conversion="copy"]',
			);
			const copyLabel = selectRequired<HTMLElement>(
				'[data-conversion="copy-label"]',
			);
			const download = selectRequired<HTMLButtonElement>(
				'[data-conversion="download"]',
			);
			const reset = selectRequired<HTMLButtonElement>(
				'[data-conversion="reset"]',
			);

			let state: State = { status: "idle" };
			let copyResetTimer: number | null = null;
			let historyItems: string[] = [];
			let historyActive = -1;

			const closeHistory = () => {
				historyList.hidden = true;
				historyActive = -1;
				input.setAttribute("aria-expanded", "false");
				input.removeAttribute("aria-activedescendant");
			};

			const setHistoryActive = (index: number) => {
				historyActive = index;
				const options = Array.from(historyList.children);
				options.forEach((option, optionIndex) => {
					option.setAttribute(
						"aria-selected",
						optionIndex === index ? "true" : "false",
					);
				});
				if (index >= 0 && options[index]) {
					input.setAttribute("aria-activedescendant", options[index].id);
					options[index].scrollIntoView({ block: "nearest" });
				} else {
					input.removeAttribute("aria-activedescendant");
				}
			};

			const updateSubmitState = () => {
				submit.disabled =
					state.status === "submitting" || !isValidUrl(input.value);
			};

			const applyHistoryUrl = (url: string) => {
				input.value = stripScheme(url);
				closeHistory();
				input.focus();
				input.setSelectionRange(input.value.length, input.value.length);
				updateSubmitState();
			};

			const updateHistoryControls = () => {
				const enabled = isUrlHistoryEnabled();
				rememberHistory.checked = enabled;
				clearHistoryButton.hidden = !enabled || getRecentUrls().length === 0;
			};

			const buildHistoryOption = (url: string, index: number) => {
				const option = document.createElement("li");
				option.id = `${format}-history-opt-${index}`;
				option.setAttribute("role", "option");
				option.setAttribute("aria-selected", "false");
				option.className =
					"group flex cursor-pointer items-center gap-2 px-3 py-2 text-[15px] text-ink aria-selected:bg-surface hover:bg-surface";

				const label = document.createElement("span");
				label.className = "flex-1 truncate";
				label.title = url;
				label.textContent = url;
				option.appendChild(label);

				const remove = document.createElement("button");
				remove.type = "button";
				remove.tabIndex = -1;
				remove.className =
					"shrink-0 rounded-md p-1 text-ink-2 opacity-0 transition group-hover:opacity-100 hover:bg-hair/50 hover:text-ink";
				remove.setAttribute("aria-label", `Remove ${url} from recent`);
				remove.textContent = "×";
				remove.addEventListener("mousedown", (event) => {
					event.preventDefault();
					event.stopPropagation();
				});
				remove.addEventListener("click", (event) => {
					event.preventDefault();
					event.stopPropagation();
					removeRecentUrl(url);
					renderHistory();
					updateHistoryControls();
					input.focus();
				});
				option.appendChild(remove);
				option.addEventListener("mousedown", (event) => event.preventDefault());
				option.addEventListener("click", () => applyHistoryUrl(url));
				option.addEventListener("mousemove", () => setHistoryActive(index));
				return option;
			};

			function renderHistory() {
				if (!isUrlHistoryEnabled() || state.status === "submitting") {
					closeHistory();
					updateHistoryControls();
					return;
				}
				const query = input.value.trim().toLowerCase();
				historyItems = getRecentUrls().filter((url) => {
					const lower = url.toLowerCase();
					return query === "" ? true : lower.includes(query) && lower !== query;
				});
				historyList.replaceChildren();
				historyActive = -1;
				input.removeAttribute("aria-activedescendant");
				if (historyItems.length === 0) {
					closeHistory();
					updateHistoryControls();
					return;
				}
				historyItems.forEach((url, index) => {
					historyList.appendChild(buildHistoryOption(url, index));
				});
				historyList.hidden = false;
				input.setAttribute("aria-expanded", "true");
				updateHistoryControls();
			}

			const handleHistoryKeydown = (event: KeyboardEvent) => {
				const open = !historyList.hidden;
				if (event.key === "ArrowDown") {
					if (!open) {
						renderHistory();
						if (!historyList.hidden) setHistoryActive(0);
					} else {
						setHistoryActive(Math.min(historyActive + 1, historyItems.length - 1));
					}
					if (!historyList.hidden) event.preventDefault();
				} else if (event.key === "ArrowUp" && open) {
					setHistoryActive(historyActive <= 0 ? -1 : historyActive - 1);
					event.preventDefault();
				} else if (event.key === "Enter" && open && historyActive >= 0) {
					event.preventDefault();
					applyHistoryUrl(historyItems[historyActive]);
				} else if (event.key === "Escape" && open) {
					event.preventDefault();
					closeHistory();
				}
			};

			const render = () => {
				const isSubmitting = state.status === "submitting";
				input.disabled = isSubmitting;
				rememberHistory.disabled = isSubmitting;
				submitLabel.textContent = isSubmitting ? "Converting..." : "Convert";
				spinner.hidden = !isSubmitting;
				updateSubmitState();

				if (state.status === "error") {
					errorElement.hidden = false;
					errorElement.textContent = state.message;
					input.setAttribute("aria-invalid", "true");
					inputShell.setAttribute("aria-invalid", "true");
				} else {
					errorElement.hidden = true;
					errorElement.textContent = "";
					input.setAttribute("aria-invalid", "false");
					inputShell.setAttribute("aria-invalid", "false");
				}

				if (state.status === "success") {
					source.href = state.sourceUrl;
					source.textContent = state.sourceUrl;
					source.title = state.sourceUrl;
					output.value = state.content;
					meta.textContent = `${state.content.length.toLocaleString()} characters`;
					result.hidden = false;
				} else {
					result.hidden = true;
				}
			};

			const handleSubmit = async (event: SubmitEvent) => {
				event.preventDefault();
				if (state.status === "submitting") return;
				const url = normalizeUserUrlInput(input.value);
				if (!url || !isValidUrl(url)) {
					state = { status: "error", message: "Please enter a valid URL." };
					render();
					input.focus();
					return;
				}
				closeHistory();
				state = { status: "submitting" };
				render();
				try {
					const converted = await convertUrl(url, format, signal);
					if (isUrlHistoryEnabled()) {
						addRecentUrl(url);
						updateHistoryControls();
					}
					state = { status: "success", ...converted };
					render();
					copy.focus();
				} catch (error) {
					state = { status: "error", message: friendlyErrorMessage(error) };
					render();
					input.focus();
				}
			};

			const handleCopy = async () => {
				if (state.status !== "success") return;
				if (!(await copyToClipboard(state.content))) return;
				copyLabel.textContent = "Copied";
				if (copyResetTimer !== null) window.clearTimeout(copyResetTimer);
				copyResetTimer = window.setTimeout(() => {
					copyLabel.textContent = "Copy";
					copyResetTimer = null;
				}, 1600);
			};

			const handleDownload = () => {
				if (state.status !== "success") return;
				const hostname = new URL(state.sourceUrl).hostname.replace(
					/[^a-z0-9.-]+/gi,
					"-",
				);
				const mime =
					format === "html" ? "text/html;charset=utf-8" : "text/markdown;charset=utf-8";
				const blobUrl = URL.createObjectURL(
					new Blob([state.content], { type: mime }),
				);
				const anchor = document.createElement("a");
				anchor.href = blobUrl;
				anchor.download = `${hostname || "page"}.${format === "html" ? "html" : "md"}`;
				document.body.appendChild(anchor);
				anchor.click();
				anchor.remove();
				window.setTimeout(() => URL.revokeObjectURL(blobUrl), 1000);
			};

			const handleReset = () => {
				state = { status: "idle" };
				input.value = "";
				output.value = "";
				render();
				input.focus();
			};

			form.addEventListener("submit", handleSubmit, { signal });
			rememberHistory.addEventListener(
				"change",
				() => {
					setUrlHistoryEnabled(rememberHistory.checked);
					if (!rememberHistory.checked) clearRecentUrls();
					closeHistory();
					updateHistoryControls();
				},
				{ signal },
			);
			clearHistoryButton.addEventListener(
				"click",
				() => {
					clearRecentUrls();
					closeHistory();
					updateHistoryControls();
					input.focus();
				},
				{ signal },
			);
			input.addEventListener("focus", renderHistory, { signal });
			input.addEventListener("input", renderHistory, { signal });
			input.addEventListener("input", updateSubmitState, { signal });
			input.addEventListener(
				"input",
				() => {
					const stripped = stripScheme(input.value);
					if (stripped !== input.value) input.value = stripped;
				},
				{ signal },
			);
			input.addEventListener("keydown", handleHistoryKeydown, { signal });
			document.addEventListener(
				"mousedown",
				(event) => {
					if (!inputWrap.contains(event.target as Node)) closeHistory();
				},
				{ signal },
			);
			copy.addEventListener("click", handleCopy, { signal });
			download.addEventListener("click", handleDownload, { signal });
			reset.addEventListener("click", handleReset, { signal });
			signal.addEventListener(
				"abort",
				() => {
					if (copyResetTimer !== null) window.clearTimeout(copyResetTimer);
				},
				{ once: true },
			);

			updateHistoryControls();
			render();
		},
	);
</script>
