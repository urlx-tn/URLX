---
---

<form
	class="flex flex-col gap-3 sm:flex-row"
	data-form="url-shortener"
	novalidate
>
	<label class="sr-only" for="url-input">Long URL to shorten</label>
	<div class="relative flex-1" data-form="input-wrap">
		<div
			class="field flex w-full items-center gap-2 overflow-hidden pl-4"
			data-form="input-shell"
		>
			<span
				class="shrink-0 select-none text-[15px] text-ink-2"
				data-form="scheme-prefix"
				aria-hidden="true"
			>
				https://
			</span>
			<input
				id="url-input"
				name="url"
				type="url"
				inputmode="url"
				autocomplete="off"
				spellcheck="false"
				autocapitalize="off"
				placeholder="example.com"
				class="min-w-0 flex-1 bg-transparent text-[15px] text-ink placeholder:text-ink-2/70 focus:outline-none"
				data-form="url-input"
				role="combobox"
				aria-invalid="false"
				aria-expanded="false"
				aria-autocomplete="list"
				aria-haspopup="listbox"
				aria-controls="url-history"
				aria-describedby="url-form-error"
			/>
		</div>
		<ul
			id="url-history"
			class="absolute inset-x-0 top-full z-30 mt-2 max-h-[280px] overflow-auto rounded-xl border border-hair bg-white py-1 shadow-[0_8px_30px_rgb(0_0_0/0.08)]"
			role="listbox"
			aria-label="Recent URLs"
			data-form="history"
			hidden
		>
		</ul>
	</div>
	<button
		type="submit"
		class="btn w-full sm:w-auto sm:min-w-[148px]"
		data-form="submit"
	>
		<span class="spinner shrink-0" aria-hidden="true" data-form="submit-spinner" hidden></span>
		<span data-form="submit-label">Shorten URL</span>
	</button>
</form>
<p
	id="url-form-error"
	class="mt-3 text-[14px] leading-5 text-[#d70015]"
	role="alert"
	aria-live="assertive"
	data-form="error"
	hidden
>
	<span data-form="error-message"></span>
</p>
