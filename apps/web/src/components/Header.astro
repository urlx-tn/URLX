---
import logo from "../assets/logo.png";
import {
	additionalTools,
	allToolsLink,
	isNavigationLinkActive,
	primaryProducts,
} from "../lib/navigation";
import LinkInBioIcon from "./icons/LinkInBioIcon.astro";
import QRCodeGeneratorIcon from "./icons/QRCodeGeneratorIcon.astro";
import UrlCleanerIcon from "./icons/UrlCleanerIcon.astro";
import UrlShortenerIcon from "./icons/UrlShortenerIcon.astro";
import UrlToHtmlIcon from "./icons/UrlToHtmlIcon.astro";
import UrlToMarkdownIcon from "./icons/UrlToMarkdownIcon.astro";

const headerSearchQuery =
	Astro.url.pathname === "/tools/link-in-bio/search"
		? (Astro.url.searchParams.get("q") ?? "")
		: "";
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const showHeaderSearch = currentPath === "/tools/link-in-bio";
const isAdditionalToolActive = additionalTools.some((link) =>
	isNavigationLinkActive(currentPath, link.href),
);
const createTools = primaryProducts.filter(
	(link) => link.category === "Create",
);
const cleanTools = additionalTools.filter((link) => link.category === "Clean");
const conversionTools = additionalTools.filter(
	(link) => link.category === "Convert",
);
const toolIcons = {
	"/tools/url-shortener": UrlShortenerIcon,
	"/tools/qr-code-generator": QRCodeGeneratorIcon,
	"/tools/link-in-bio": LinkInBioIcon,
	"/tools/url-cleaner": UrlCleanerIcon,
	"/tools/url-to-markdown": UrlToMarkdownIcon,
	"/tools/url-to-html": UrlToHtmlIcon,
};
---

<header
	data-header-root
	class="sticky top-0 z-20 border-b border-hair/70 bg-white/75 backdrop-blur-xl backdrop-saturate-150"
>
	<div
		class="mx-auto flex h-14 w-full max-w-[980px] items-center justify-between px-6"
	>
		<a
			href="/"
			class="inline-flex items-center no-underline"
			aria-label="URLX home"
		>
			<img
				src={logo.src}
				alt="URLX"
				width="1033"
				height="274"
				class="h-[26px] w-auto"
				loading="eager"
				fetchpriority="high"
			/>
		</a>
		<nav class="flex items-center gap-2">
			{
				showHeaderSearch && (
					<>
						<form
							action="/tools/link-in-bio/search"
							method="get"
							class="field-compact relative hidden h-9 w-[180px] items-center gap-2 px-3 lg:flex xl:w-[220px]"
							data-header-search="form"
							role="search"
						>
							<label class="sr-only" for="header-search">Search link pages</label>
							<svg
								viewBox="0 0 24 24"
								class="size-4 shrink-0 text-ink-2"
								fill="none"
								stroke="currentColor"
								stroke-width="1.7"
								stroke-linecap="round"
								stroke-linejoin="round"
								aria-hidden="true"
							>
								<circle cx="11" cy="11" r="7" />
								<path d="m16.5 16.5 4 4" />
							</svg>
							<input
								id="header-search"
								name="q"
								type="search"
								maxlength="80"
								value={headerSearchQuery}
								placeholder="Search"
								autocomplete="off"
								aria-controls="header-search-findings"
								aria-expanded="false"
								class="min-w-0 flex-1 bg-transparent text-[14px] text-ink placeholder:text-ink-2/70 focus:outline-none"
								data-header-search="input"
							/>
							<ul
								id="header-search-findings"
								class="absolute inset-x-0 top-full z-40 mt-2 max-h-[320px] overflow-auto rounded-xl border border-hair bg-white p-1.5 shadow-[0_16px_44px_rgb(0_0_0/0.14)]"
								data-header-search="findings"
								role="listbox"
								hidden
							>
							</ul>
						</form>
						<a
							href="/tools/link-in-bio/search"
							class="inline-flex h-9 items-center justify-center rounded-xl px-3 text-[14px] font-medium text-ink no-underline hover:bg-surface lg:hidden"
						>
							Search
						</a>
					</>
				)
			}
			<div class="hidden items-center gap-1 lg:flex">
				{
					primaryProducts.map((link) => (
						<a
							href={link.href}
							aria-current={isNavigationLinkActive(currentPath, link.href)
								? "page"
								: undefined}
							class:list={[
								"inline-flex h-9 items-center justify-center rounded-xl px-3 text-[14px] font-medium whitespace-nowrap no-underline transition-colors",
								isNavigationLinkActive(currentPath, link.href)
									? "bg-surface text-ink"
									: "text-ink-2 hover:bg-surface hover:text-ink",
							]}
						>
							{link.navLabel}
						</a>
					))
				}
				<div class="group relative" data-more-tools="menu">
					<button
						type="button"
						aria-current={isAdditionalToolActive ? "page" : undefined}
						aria-haspopup="true"
						aria-expanded="false"
						data-more-tools="toggle"
						class:list={[
							"inline-flex h-9 items-center justify-center rounded-xl px-3 text-[14px] font-medium whitespace-nowrap no-underline transition-colors",
							isAdditionalToolActive
								? "bg-surface text-ink"
								: "text-ink-2 hover:bg-surface hover:text-ink",
						]}
					>
						More tools
						<svg
							viewBox="0 0 24 24"
							class="ml-1 size-3.5 transition-transform duration-150 group-hover:rotate-180 group-focus-within:rotate-180"
							data-more-tools="toggle-icon"
							fill="none"
							stroke="currentColor"
							stroke-width="1.8"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<path d="m6 9 6 6 6-6" />
						</svg>
					</button>
					<div
						class="invisible absolute right-0 top-full z-40 w-[min(720px,calc(100vw-3rem))] translate-y-1 pt-3 opacity-0 transition duration-150 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100"
						data-more-tools="panel"
					>
						<div
							class="relative rounded-2xl border border-hair/80 bg-white p-5 shadow-[0_22px_60px_rgb(0_0_0/0.16)]"
						>
							<span
								class="absolute -top-2 right-12 size-4 rotate-45 border-l border-t border-hair/80 bg-white"
								aria-hidden="true"
							></span>
							<div class="grid grid-cols-3 gap-5">
								<section>
									<p
										class="px-2 text-[11px] font-semibold uppercase tracking-[0.08em] text-ink-2"
									>
										Create
									</p>
									<div class="mt-2 space-y-1">
										{
											createTools.map((link) => {
												const Icon = toolIcons[link.href];
												return (
													<a
														href={link.href}
														aria-current={isNavigationLinkActive(
															currentPath,
															link.href,
														)
															? "page"
															: undefined}
														class:list={[
															"flex items-center gap-3 rounded-xl p-2.5 no-underline transition-colors",
															isNavigationLinkActive(currentPath, link.href)
																? "bg-surface"
																: "hover:bg-surface",
														]}
													>
														<span class="grid size-12 shrink-0 place-items-center">
															<Icon class="h-10 w-11 object-contain" />
														</span>
														<span class="min-w-0">
															<span class="block text-[14px] font-semibold text-ink">
																{link.label}
															</span>
															<span class="mt-0.5 block text-[12px] leading-4 text-ink-2">
																{link.description}
															</span>
														</span>
													</a>
												);
											})
										}
									</div>
								</section>
								<section>
									<p
										class="px-2 text-[11px] font-semibold uppercase tracking-[0.08em] text-ink-2"
									>
										Clean
									</p>
									<div class="mt-2 space-y-1">
										{
											cleanTools.map((link) => {
												const Icon = toolIcons[link.href];
												return (
													<a
														href={link.href}
														aria-current={isNavigationLinkActive(
															currentPath,
															link.href,
														)
															? "page"
															: undefined}
														class:list={[
															"group/tool flex items-center gap-3 rounded-xl p-2.5 no-underline transition-colors",
															isNavigationLinkActive(currentPath, link.href)
																? "bg-surface"
																: "hover:bg-surface",
														]}
													>
														<span class="grid size-12 shrink-0 place-items-center">
															<Icon class="h-10 w-11 object-contain" />
														</span>
														<span class="min-w-0">
															<span class="block text-[14px] font-semibold text-ink">
																{link.label}
															</span>
															<span class="mt-0.5 block text-[12px] leading-4 text-ink-2">
																{link.description}
															</span>
														</span>
													</a>
												);
											})
										}
									</div>
								</section>
								<section>
									<p
										class="px-2 text-[11px] font-semibold uppercase tracking-[0.08em] text-ink-2"
									>
										Convert
									</p>
									<div class="mt-2 space-y-1">
										{
											conversionTools.map((link) => {
												const Icon = toolIcons[link.href];
												return (
													<a
														href={link.href}
														aria-current={isNavigationLinkActive(
															currentPath,
															link.href,
														)
															? "page"
															: undefined}
														class:list={[
															"group/tool flex items-center gap-3 rounded-xl p-2.5 no-underline transition-colors",
															isNavigationLinkActive(currentPath, link.href)
																? "bg-surface"
																: "hover:bg-surface",
														]}
													>
														<span class="grid size-12 shrink-0 place-items-center">
															<Icon class="h-10 w-11 object-contain" />
														</span>
														<span class="min-w-0">
															<span class="block text-[14px] font-semibold text-ink">
																{link.label}
															</span>
															<span class="mt-0.5 block text-[12px] leading-4 text-ink-2">
																{link.description}
															</span>
														</span>
													</a>
												);
											})
										}
									</div>
								</section>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="relative lg:hidden" data-product-nav="menu">
				<button
					type="button"
					class="inline-flex h-9 items-center justify-center rounded-xl px-3 text-[14px] font-medium text-ink hover:bg-surface"
					data-product-nav="toggle"
					aria-expanded="false"
					aria-haspopup="true"
				>
					Products
					<svg
						viewBox="0 0 24 24"
						class="ml-1 size-4 transition-transform"
						data-product-nav="toggle-icon"
						fill="none"
						stroke="currentColor"
						stroke-width="1.8"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="m6 9 6 6 6-6" />
					</svg>
				</button>
				<div
					class="absolute right-0 top-full z-40 mt-2 hidden w-64 rounded-xl border border-hair bg-white p-1.5 shadow-[0_16px_44px_rgb(0_0_0/0.14)]"
					data-product-nav="panel"
				>
					{
						primaryProducts.map((link) => (
							<a
								href={link.href}
								aria-current={isNavigationLinkActive(currentPath, link.href)
									? "page"
									: undefined}
								class:list={[
									"block rounded-lg px-3 py-2 text-[14px] font-medium text-ink no-underline",
									isNavigationLinkActive(currentPath, link.href)
										? "bg-surface"
										: "hover:bg-surface",
								]}
							>
								{link.label}
							</a>
						))
					}
					<p
						class="mx-3 mb-1 mt-2 border-t border-hair/70 pt-3 text-[11px] font-semibold uppercase tracking-[0.06em] text-ink-2"
					>
						More tools
					</p>
					{
						additionalTools.map((link) => (
							<a
								href={link.href}
								aria-current={isNavigationLinkActive(currentPath, link.href)
									? "page"
									: undefined}
								class:list={[
									"block rounded-lg px-3 py-2 text-[14px] font-medium text-ink no-underline",
									isNavigationLinkActive(currentPath, link.href)
										? "bg-surface"
										: "hover:bg-surface",
								]}
							>
								{link.label}
							</a>
						))
					}
					<a
						href={allToolsLink.href}
						class="mt-1 block rounded-lg px-3 py-2 text-[13px] font-medium text-link no-underline hover:bg-surface"
					>
						Browse all tools &rarr;
					</a>
				</div>
			</div>
			<a
				href="https://github.com/urlx-tn/URLX"
				target="_blank"
				rel="noopener noreferrer"
				class="btn-secondary inline-flex h-9 items-center justify-center gap-2 rounded-xl border px-2.5 text-[14px] font-medium no-underline sm:px-4"
				aria-label="View URLX on GitHub"
			>
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="currentColor"
					class="h-4 w-4"
					aria-hidden="true"
				>
					<path
						fill-rule="evenodd"
						clip-rule="evenodd"
						d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"
					>
					</path>
				</svg>
				<span class="hidden sm:inline">GitHub</span>
			</a>
		</nav>
	</div>
</header>

<script>
	import { navigate } from "astro:transitions/client";
	import { orpc } from "../lib/orpc";
	import { registerPageScript } from "../lib/page-script";

	const FINDINGS_SIZE = 3;
	const FINDINGS_DELAY = 180;

	type HeaderSearchItem = {
		slug: string;
		title: string;
		description: string | null;
		createdAt: number;
	};

	registerPageScript<HTMLElement>("[data-header-root]", (header, signal) => {
		const form = header.querySelector<HTMLFormElement>(
			'[data-header-search="form"]',
		);
		const input = header.querySelector<HTMLInputElement>(
			'[data-header-search="input"]',
		);
		const findingsList = header.querySelector<HTMLUListElement>(
			'[data-header-search="findings"]',
		);

		const productNavMenu = header.querySelector<HTMLElement>(
			'[data-product-nav="menu"]',
		);
		const productNavToggle = header.querySelector<HTMLButtonElement>(
			'[data-product-nav="toggle"]',
		);
		const productNavPanel = header.querySelector<HTMLElement>(
			'[data-product-nav="panel"]',
		);
		const productNavToggleIcon = header.querySelector<HTMLElement>(
			'[data-product-nav="toggle-icon"]',
		);
		const moreToolsMenu = header.querySelector<HTMLElement>(
			'[data-more-tools="menu"]',
		);
		const moreToolsToggle = header.querySelector<HTMLButtonElement>(
			'[data-more-tools="toggle"]',
		);
		const moreToolsPanel = header.querySelector<HTMLElement>(
			'[data-more-tools="panel"]',
		);
		const moreToolsToggleIcon = header.querySelector<HTMLElement>(
			'[data-more-tools="toggle-icon"]',
		);

		let timer: number | null = null;
		let requestToken = 0;
		let activeIndex = -1;
		let currentItems: HeaderSearchItem[] = [];
		let currentQuery = "";
		let productNavOpen = false;
		let moreToolsOpen = false;

		const normalizeQueryInput = (value: string) =>
			value
				.trim()
				.replace(/^https?:\/\/[^/]+\/p\//i, "")
				.replace(/^\/?p\//i, "")
				.replace(/^@/, "")
				.slice(0, 80);

		const closeFindings = () => {
			findingsList && (findingsList.hidden = true);
			currentItems = [];
			activeIndex = -1;
			input?.setAttribute("aria-expanded", "false");
			input?.removeAttribute("aria-activedescendant");
		};

		const setProductNavOpen = (open: boolean) => {
			productNavOpen = open;
			if (productNavPanel) {
				productNavPanel.classList.toggle("hidden", !open);
			}
			if (productNavToggle) {
				productNavToggle.setAttribute("aria-expanded", open ? "true" : "false");
			}
			if (productNavToggleIcon) {
				productNavToggleIcon.style.transform = open ? "rotate(180deg)" : "";
			}
		};

		const setMoreToolsOpen = (open: boolean) => {
			moreToolsOpen = open;
			if (moreToolsPanel) {
				moreToolsPanel.classList.toggle("invisible", !open);
				moreToolsPanel.classList.toggle("translate-y-1", !open);
				moreToolsPanel.classList.toggle("opacity-0", !open);
				moreToolsPanel.classList.toggle("visible", open);
				moreToolsPanel.classList.toggle("translate-y-0", open);
				moreToolsPanel.classList.toggle("opacity-100", open);
			}
			moreToolsToggle?.setAttribute("aria-expanded", open ? "true" : "false");
			if (moreToolsToggleIcon) {
				moreToolsToggleIcon.style.transform = open ? "rotate(180deg)" : "";
			}
		};

		const setActiveFinding = (index: number) => {
			activeIndex = index;
			const options = Array.from(findingsList?.children ?? []);
			options.forEach((option, optionIndex) => {
				option.setAttribute(
					"aria-selected",
					optionIndex === activeIndex ? "true" : "false",
				);
			});

			if (activeIndex >= 0 && options[activeIndex]) {
				input?.setAttribute("aria-activedescendant", options[activeIndex].id);
				options[activeIndex].scrollIntoView({ block: "nearest" });
			} else {
				input?.removeAttribute("aria-activedescendant");
			}
		};

		const searchUrl = (searchQuery: string) => {
			const params = new URLSearchParams();
			if (searchQuery) {
				params.set("q", searchQuery);
			}

			const suffix = params.toString();
			return suffix
				? `/tools/link-in-bio/search?${suffix}`
				: "/tools/link-in-bio/search";
		};

		const openPage = (item: HeaderSearchItem) => {
			navigate(`/p/${item.slug}`);
		};

		const openAllResults = () => {
			navigate(
				currentItems.length === 0
					? "/tools/link-in-bio/search"
					: searchUrl(currentQuery),
			);
		};

		const createFindingOption = (item: HeaderSearchItem, index: number) => {
			const option = document.createElement("li");
			option.id = `header-search-finding-${index}`;
			option.setAttribute("role", "option");
			option.setAttribute("aria-selected", "false");
			option.className =
				"flex cursor-pointer items-center gap-3 rounded-lg px-3 py-2.5 text-left aria-selected:bg-surface hover:bg-surface";

			const avatar = document.createElement("span");
			avatar.className =
				"grid size-8 shrink-0 place-items-center rounded-lg bg-surface text-[12px] font-semibold uppercase text-ink-2 ring-1 ring-black/5";
			avatar.textContent = item.title.trim().charAt(0) || "#";
			avatar.setAttribute("aria-hidden", "true");

			const content = document.createElement("span");
			content.className = "min-w-0 flex-1";

			const title = document.createElement("span");
			title.className = "block truncate text-[13px] font-semibold text-ink";
			title.textContent = item.title;

			const handle = document.createElement("span");
			handle.className = "mt-0.5 block truncate text-[12px] text-ink-2";
			handle.textContent = `@${item.slug}`;

			content.appendChild(title);
			content.appendChild(handle);
			option.appendChild(avatar);
			option.appendChild(content);
			option.addEventListener("mousedown", (event) => event.preventDefault());
			option.addEventListener("mousemove", () => setActiveFinding(index));
			option.addEventListener("click", () => openPage(item));
			return option;
		};

		const createViewAllOption = (index: number, totalItems: number) => {
			const option = document.createElement("li");
			option.id = `header-search-finding-${index}`;
			option.setAttribute("role", "option");
			option.setAttribute("aria-selected", "false");
			option.className =
				"mt-1 flex cursor-pointer items-center gap-3 rounded-lg border-t border-hair/70 px-3 py-2.5 pt-3 text-left aria-selected:bg-surface hover:bg-surface";

			const icon = document.createElement("span");
			icon.className =
				"grid size-8 shrink-0 place-items-center rounded-lg bg-surface text-ink-2 ring-1 ring-black/5";
			icon.innerHTML =
				'<svg viewBox="0 0 24 24" class="size-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';
			icon.setAttribute("aria-hidden", "true");

			const content = document.createElement("span");
			content.className = "min-w-0 flex-1";

			const title = document.createElement("span");
			title.className = "block truncate text-[13px] font-semibold text-ink";
			title.textContent =
				totalItems === 0 && currentQuery
					? `No results for "${currentQuery}"`
					: currentQuery
						? `View all results for "${currentQuery}"`
						: "View all link pages";

			const meta = document.createElement("span");
			meta.className = "mt-0.5 block truncate text-[12px] text-ink-2";
			if (totalItems === 0 && currentQuery) {
				meta.textContent = "See all link pages";
			} else if (totalItems > currentItems.length) {
				meta.textContent = `${totalItems} total matches`;
			} else {
				meta.textContent = "Open the full search page";
			}

			content.appendChild(title);
			content.appendChild(meta);
			option.appendChild(icon);
			option.appendChild(content);
			option.addEventListener("mousedown", (event) => event.preventDefault());
			option.addEventListener("mousemove", () => setActiveFinding(index));
			option.addEventListener("click", openAllResults);
			return option;
		};

		const renderFindings = (items: HeaderSearchItem[], totalItems: number) => {
			currentItems = items;
			if (!findingsList) return;
			findingsList.replaceChildren();

			const fragment = document.createDocumentFragment();
			items.forEach((item, index) => {
				fragment.appendChild(createFindingOption(item, index));
			});
			fragment.appendChild(createViewAllOption(items.length, totalItems));
			findingsList.appendChild(fragment);
			findingsList.hidden = false;
			input?.setAttribute("aria-expanded", "true");
			setActiveFinding(-1);
		};

		const fetchFindings = async () => {
			const query = normalizeQueryInput(input?.value ?? "");
			requestToken += 1;
			const token = requestToken;
			currentQuery = query;

			if (!query) {
				closeFindings();
				return;
			}

			try {
				const result = await orpc.bio.search({
					query,
					page: 1,
					pageSize: FINDINGS_SIZE,
				});

				if (token !== requestToken) return;
				renderFindings(result.items, result.totalItems);
			} catch {
				if (token !== requestToken) return;
				closeFindings();
			}
		};

		const scheduleFindings = () => {
			if (timer !== null) {
				window.clearTimeout(timer);
			}

			timer = window.setTimeout(() => {
				timer = null;
				void fetchFindings();
			}, FINDINGS_DELAY);
		};

		form?.addEventListener(
			"submit",
			() => {
				closeFindings();
				if (input) {
					input.value = normalizeQueryInput(input.value);
				}
			},
			{ signal },
		);
		input?.addEventListener("input", scheduleFindings, { signal });
		input?.addEventListener("focus", scheduleFindings, { signal });
		input?.addEventListener(
			"keydown",
			(event) => {
				const list = findingsList;
				if (!list || list.hidden) return;

				if (event.key === "ArrowDown") {
					event.preventDefault();
					setActiveFinding(
						Math.min(activeIndex + 1, list.children.length - 1),
					);
					return;
				}

				if (event.key === "ArrowUp") {
					event.preventDefault();
					setActiveFinding(Math.max(activeIndex - 1, -1));
					return;
				}

				if (event.key === "Enter" && activeIndex >= 0) {
					event.preventDefault();
					const item = currentItems[activeIndex];
					if (item) {
						openPage(item);
					} else {
						openAllResults();
					}
					return;
				}

				if (event.key === "Escape") {
					event.preventDefault();
					closeFindings();
				}
			},
			{ signal },
		);

		productNavToggle?.addEventListener(
			"click",
			() => {
				setProductNavOpen(!productNavOpen);
			},
			{ signal },
		);

		moreToolsToggle?.addEventListener(
			"click",
			() => {
				setMoreToolsOpen(!moreToolsOpen);
			},
			{ signal },
		);
		moreToolsMenu?.addEventListener(
			"mouseenter",
			() => setMoreToolsOpen(true),
			{ signal },
		);
		moreToolsMenu?.addEventListener(
			"mouseleave",
			() => setMoreToolsOpen(false),
			{ signal },
		);

		document.addEventListener(
			"mousedown",
			(event) => {
				const target = event.target as Node;
				if (form && !form.contains(target)) {
					closeFindings();
				}
				if (productNavMenu && !productNavMenu.contains(target)) {
					setProductNavOpen(false);
				}
				if (moreToolsMenu && !moreToolsMenu.contains(target)) {
					setMoreToolsOpen(false);
				}
			},
			{ signal },
		);

		signal.addEventListener(
			"abort",
			() => {
				if (timer !== null) {
					window.clearTimeout(timer);
				}
			},
			{ once: true },
		);
	});
</script>
