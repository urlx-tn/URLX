---
import { Image } from "astro:assets";
import logo from "../assets/logo.png";
---

<header
	class="sticky top-0 z-20 border-b border-hair/70 bg-white/75 backdrop-blur-xl backdrop-saturate-150"
>
	<div
		class="mx-auto flex h-14 w-full max-w-[980px] items-center justify-between px-6"
	>
		<a
			href="/"
			class="inline-flex items-center no-underline"
			aria-label="URLX home"
		>
			<Image
				src={logo}
				alt="URLX"
				width="1033"
				height="274"
				class="h-[26px] w-auto"
				loading="eager"
				fetchpriority="high"
			/>
		</a>
		<a
			href="#url-input"
			class="btn-secondary inline-flex h-9 items-center justify-center rounded-xl border px-4 text-[14px] font-medium no-underline"
		>
			Shorten a link
		</a>
	</div>
</header>
