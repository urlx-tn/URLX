---
import Layout from "../../layouts/Layout.astro";

const title = "QR Code Generator | URLX";
const description =
	"Create a downloadable QR code from any link. Free, private, and no sign-up required.";

const pageUrl = new URL("/tools/qr-code-generator", Astro.site).toString();

const softwareSchema = {
	"@context": "https://schema.org",
	"@type": "WebApplication",
	name: "QR Code Generator",
	applicationCategory: "UtilitiesApplication",
	operatingSystem: "Web",
	offers: {
		"@type": "Offer",
		price: "0",
		priceCurrency: "USD",
	},
	url: pageUrl,
};
---

<Layout title={title} description={description}>
	<script is:inline type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />

	<section
		data-page-root="qr-code-generator"
		class="flex flex-1 items-center bg-white"
	>
		<div class="mx-auto w-full max-w-[800px] px-6 pt-16 pb-24 text-center sm:pb-28">
			<h1
				class="text-[40px] font-semibold leading-[1.05] tracking-[-0.02em] text-ink sm:text-[56px]"
			>
				QR code generator.
			</h1>
			<p
				class="mx-auto mt-5 max-w-[32ch] text-[19px] leading-7 text-ink-2 sm:text-[21px]"
			>
				Paste a link and create a clean QR code you can download.
			</p>

			<div class="mx-auto mt-10 max-w-[560px] text-left">
				<form
					class="flex flex-col gap-3"
					data-qr-generator="form"
					novalidate
				>
					<div class="flex flex-col gap-3 sm:flex-row">
						<label class="sr-only" for="qr-url-input">Link to encode</label>
						<div class="relative flex-1" data-qr-generator="input-wrap">
							<div
								class="field flex w-full items-center gap-2 overflow-hidden pl-4"
								data-qr-generator="input-shell"
							>
								<span
									class="shrink-0 select-none text-[15px] text-ink-2"
									aria-hidden="true"
								>
									https://
								</span>
								<input
									id="qr-url-input"
									name="url"
									type="url"
									inputmode="url"
									autocomplete="off"
									spellcheck="false"
									autocapitalize="off"
									placeholder="example.com"
									class="min-w-0 flex-1 bg-transparent text-[15px] text-ink placeholder:text-ink-2/70 focus:outline-none"
									data-qr-generator="url-input"
									role="combobox"
									aria-invalid="false"
									aria-expanded="false"
									aria-autocomplete="list"
									aria-haspopup="listbox"
									aria-controls="qr-url-history"
									aria-describedby="qr-generator-error"
								/>
							</div>
							<ul
								id="qr-url-history"
								class="absolute inset-x-0 top-full z-30 mt-2 max-h-[280px] overflow-auto rounded-xl border border-hair bg-white py-1 shadow-[0_8px_30px_rgb(0_0_0/0.08)]"
								role="listbox"
								aria-label="Recent URLs"
								data-qr-generator="history"
								hidden
							>
							</ul>
						</div>
						<button
							type="submit"
							class="btn w-full sm:w-auto sm:min-w-[168px]"
							data-qr-generator="submit"
						>
							<span
								class="spinner shrink-0"
								aria-hidden="true"
								data-qr-generator="submit-spinner"
								hidden
							>
							</span>
							<span data-qr-generator="submit-label">Generate QR code</span>
						</button>
					</div>
					<div
						class="flex flex-col gap-2 text-[13px] leading-5 text-ink-2 sm:flex-row sm:items-center sm:justify-between"
					>
						<label class="inline-flex items-center gap-2">
							<input
								type="checkbox"
								class="h-4 w-4 accent-accent"
								data-qr-generator="remember-history"
							/>
							<span>Remember recent URLs on this device</span>
						</label>
						<button
							type="button"
							class="self-start text-link underline-offset-2 hover:underline sm:self-auto"
							data-qr-generator="clear-history"
							hidden
						>
							Clear recent URLs
						</button>
					</div>
				</form>

				<p
					id="qr-generator-error"
					class="mt-3 text-[14px] leading-5 text-[#d70015]"
					role="alert"
					aria-live="assertive"
					data-qr-generator="error"
					hidden
				>
				</p>

				<section
					class="surface reveal mt-8 p-6 text-left sm:p-7"
					data-qr-generator="result"
					aria-labelledby="qr-result-label"
					aria-live="polite"
					hidden
				>
					<h2
						id="qr-result-label"
						class="text-[13px] font-semibold uppercase tracking-[0.06em] text-ink-2"
					>
						Your QR code
					</h2>

					<div class="mt-5 flex justify-center">
						<div
							class="flex h-[232px] w-[232px] items-center justify-center rounded-xl border border-hair bg-white p-3"
							data-qr-generator="canvas"
							role="img"
							aria-label="QR code"
						>
						</div>
					</div>

					<div class="mt-5 flex flex-wrap justify-center gap-2.5">
						<button
							type="button"
							class="btn-secondary inline-flex h-10 items-center justify-center rounded-xl border px-4 text-[14px] font-medium"
							data-qr-generator="download-svg"
						>
							Download SVG
						</button>
						<button
							type="button"
							class="btn-secondary inline-flex h-10 items-center justify-center rounded-xl border px-4 text-[14px] font-medium"
							data-qr-generator="download-png"
						>
							<span data-qr-generator="download-png-label">Download PNG</span>
						</button>
					</div>
				</section>
			</div>
		</div>
	</section>
</Layout>

<script>
	import { registerPageScript } from "../../lib/page-script";
	import { renderQrPngDataUrl, renderQrSvg } from "../../lib/qr-code";
	import {
		addRecentUrl,
		clearRecentUrls,
		getRecentUrls,
		isUrlHistoryEnabled,
		removeRecentUrl,
		setUrlHistoryEnabled,
	} from "../../lib/url-history";

	type State =
		| { status: "idle" }
		| { status: "generating" }
		| { status: "success"; url: string; svg: string }
		| { status: "error"; message: string };

	const stripScheme = (value: string): string =>
		value.replace(/^\s*(https?|ftp):\/\//i, "");

	const isValidUrl = (raw: string): boolean => {
		const trimmed = raw.trim();
		if (!trimmed) return false;
		const candidate = `https://${stripScheme(trimmed)}`;
		if (!URL.canParse(candidate)) return false;
		const { hostname } = new URL(candidate);
		if (!hostname) return false;
		if (hostname === "localhost") return true;
		const bare = hostname.replace(/^\[|\]$/g, "");
		if (URL.canParse(`http://[${bare}]`)) return true;
		if (/^\d{1,3}(\.\d{1,3}){3}$/.test(bare)) return true;
		const labels = hostname.split(".");
		if (labels.length < 2) return false;
		if (labels.some((label) => label.length === 0)) return false;
		const tld = labels[labels.length - 1];
		return /^[a-z]{2,}$/i.test(tld) || /^xn--[a-z0-9]+$/i.test(tld);
	};

	const normalizeUrl = (raw: string): string => {
		const trimmed = raw.trim();
		return `https://${stripScheme(trimmed)}`;
	};

	const sanitizeFileSlug = (value: string): string => {
		const slug = value
			.toLowerCase()
			.replace(/[^a-z0-9]+/g, "-")
			.replace(/^-+|-+$/g, "")
			.slice(0, 50);
		return slug || "code";
	};

	const fileSlugFromUrl = (url: string): string => {
		try {
			const { hostname } = new URL(url);
			return sanitizeFileSlug(hostname);
		} catch {
			return "code";
		}
	};

	registerPageScript<HTMLElement>(
		'[data-page-root="qr-code-generator"]',
		(root, signal) => {
			const selectRequired = <T extends Element>(selector: string): T => {
				const element = root.querySelector<T>(selector);
				if (!element) {
					throw new Error(`Missing required element: ${selector}`);
				}
				return element;
			};

			const form = selectRequired<HTMLFormElement>(
				'[data-qr-generator="form"]',
			);
			const input = selectRequired<HTMLInputElement>(
				'[data-qr-generator="url-input"]',
			);
			const inputShell = selectRequired<HTMLElement>(
				'[data-qr-generator="input-shell"]',
			);
			const inputWrap = selectRequired<HTMLElement>(
				'[data-qr-generator="input-wrap"]',
			);
			const submitButton = selectRequired<HTMLButtonElement>(
				'[data-qr-generator="submit"]',
			);
			const submitLabel = selectRequired<HTMLElement>(
				'[data-qr-generator="submit-label"]',
			);
			const submitSpinner = selectRequired<HTMLElement>(
				'[data-qr-generator="submit-spinner"]',
			);
			const errorEl = selectRequired<HTMLElement>(
				'[data-qr-generator="error"]',
			);
			const canvas = selectRequired<HTMLElement>(
				'[data-qr-generator="canvas"]',
			);
			const resultPanel = selectRequired<HTMLElement>(
				'[data-qr-generator="result"]',
			);
			const downloadSvgButton = selectRequired<HTMLButtonElement>(
				'[data-qr-generator="download-svg"]',
			);
			const downloadPngButton = selectRequired<HTMLButtonElement>(
				'[data-qr-generator="download-png"]',
			);
			const downloadPngLabel = selectRequired<HTMLElement>(
				'[data-qr-generator="download-png-label"]',
			);
			const historyList = selectRequired<HTMLUListElement>(
				'[data-qr-generator="history"]',
			);
			const rememberHistory = selectRequired<HTMLInputElement>(
				'[data-qr-generator="remember-history"]',
			);
			const clearHistoryButton = selectRequired<HTMLButtonElement>(
				'[data-qr-generator="clear-history"]',
			);

			let state: State = { status: "idle" };
			let generationToken = 0;
			let historyItems: string[] = [];
			let historyActive = -1;

			const closeHistory = () => {
				historyList.hidden = true;
				historyActive = -1;
				input.setAttribute("aria-expanded", "false");
				input.removeAttribute("aria-activedescendant");
			};

			const setHistoryActive = (index: number) => {
				historyActive = index;
				const options = Array.from(historyList.children);
				options.forEach((option, i) => {
					option.setAttribute("aria-selected", i === index ? "true" : "false");
				});
				if (index >= 0 && options[index]) {
					input.setAttribute("aria-activedescendant", options[index].id);
					options[index].scrollIntoView({ block: "nearest" });
				} else {
					input.removeAttribute("aria-activedescendant");
				}
			};

			const applyHistoryUrl = (url: string) => {
				input.value = stripScheme(url);
				closeHistory();
				input.focus();
				const end = input.value.length;
				input.setSelectionRange(end, end);
				updateSubmitState();
			};

			const updateHistoryControls = () => {
				const enabled = isUrlHistoryEnabled();
				rememberHistory.checked = enabled;
				clearHistoryButton.hidden = !enabled || getRecentUrls().length === 0;
			};

			const buildHistoryOption = (url: string, index: number) => {
				const option = document.createElement("li");
				option.id = `qr-url-history-opt-${index}`;
				option.setAttribute("role", "option");
				option.setAttribute("aria-selected", "false");
				option.className =
					"group flex cursor-pointer items-center gap-2 px-3 py-2 text-[15px] text-ink aria-selected:bg-surface hover:bg-surface";

				const label = document.createElement("span");
				label.className = "flex-1 truncate";
				label.title = url;
				label.textContent = url;
				option.appendChild(label);

				const remove = document.createElement("button");
				remove.type = "button";
				remove.tabIndex = -1;
				remove.className =
					"shrink-0 rounded-md p-1 text-ink-2 opacity-0 transition group-hover:opacity-100 hover:bg-hair/50 hover:text-ink";
				remove.setAttribute("aria-label", `Remove ${url} from recent`);
				remove.innerHTML =
					'<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M4 4 12 12M12 4 4 12"/></svg>';
				remove.addEventListener("mousedown", (event) => {
					event.preventDefault();
					event.stopPropagation();
				});
				remove.addEventListener("click", (event) => {
					event.preventDefault();
					event.stopPropagation();
					removeRecentUrl(url);
					renderHistory();
					updateHistoryControls();
					input.focus();
				});
				option.appendChild(remove);

				option.addEventListener("mousedown", (event) => event.preventDefault());
				option.addEventListener("click", () => applyHistoryUrl(url));
				option.addEventListener("mousemove", () => setHistoryActive(index));
				return option;
			};

			function renderHistory() {
				if (!isUrlHistoryEnabled()) {
					closeHistory();
					updateHistoryControls();
					return;
				}

				const query = input.value.trim().toLowerCase();
				historyItems = getRecentUrls().filter((url) => {
					const lower = url.toLowerCase();
					return query === "" ? true : lower.includes(query) && lower !== query;
				});
				historyList.replaceChildren();
				historyActive = -1;
				input.removeAttribute("aria-activedescendant");
				if (historyItems.length === 0) {
					closeHistory();
					updateHistoryControls();
					return;
				}
				historyItems.forEach((url, index) => {
					historyList.appendChild(buildHistoryOption(url, index));
				});
				historyList.hidden = false;
				input.setAttribute("aria-expanded", "true");
				updateHistoryControls();
			}

			const handleHistoryKeydown = (event: KeyboardEvent) => {
				const open = !historyList.hidden;
				if (event.key === "ArrowDown") {
					if (!open) {
						renderHistory();
						if (!historyList.hidden) setHistoryActive(0);
					} else {
						setHistoryActive(Math.min(historyActive + 1, historyItems.length - 1));
					}
					if (!historyList.hidden) event.preventDefault();
				} else if (event.key === "ArrowUp") {
					if (open) {
						setHistoryActive(historyActive <= 0 ? -1 : historyActive - 1);
						event.preventDefault();
					}
				} else if (event.key === "Enter") {
					if (open && historyActive >= 0) {
						event.preventDefault();
						applyHistoryUrl(historyItems[historyActive]);
					}
				} else if (event.key === "Escape") {
					if (open) {
						event.preventDefault();
						closeHistory();
					}
				}
			};

			const updateSubmitState = () => {
				submitButton.disabled =
					state.status === "generating" || !isValidUrl(input.value);
			};

			const triggerDownload = (filename: string, href: string) => {
				const anchor = document.createElement("a");
				anchor.href = href;
				anchor.download = filename;
				document.body.appendChild(anchor);
				anchor.click();
				anchor.remove();
			};

			const render = () => {
				const isGenerating = state.status === "generating";
				input.disabled = isGenerating;
				updateSubmitState();
				submitLabel.textContent = isGenerating
					? "Generating..."
					: "Generate QR code";
				submitSpinner.hidden = !isGenerating;

				if (state.status === "error") {
					errorEl.hidden = false;
					errorEl.textContent = state.message;
					input.setAttribute("aria-invalid", "true");
					inputShell.setAttribute("aria-invalid", "true");
				} else {
					errorEl.hidden = true;
					errorEl.textContent = "";
					input.setAttribute("aria-invalid", "false");
					inputShell.setAttribute("aria-invalid", "false");
				}

				if (state.status === "success") {
					canvas.innerHTML = state.svg;
					const svgEl = canvas.querySelector("svg");
					if (svgEl) {
						svgEl.setAttribute("width", "100%");
						svgEl.setAttribute("height", "100%");
						svgEl.setAttribute("aria-label", `QR code for ${state.url}`);
					}
					resultPanel.hidden = false;
				} else {
					resultPanel.hidden = true;
					canvas.innerHTML = "";
				}
			};

			const generateQr = async (url: string) => {
				const token = generationToken + 1;
				generationToken = token;

				state = { status: "generating" };
				render();

				try {
					const svg = await renderQrSvg(url, {
						margin: 1,
						color: { dark: "#1d1d1f", light: "#ffffff" },
					});
					if (token !== generationToken) return;

					if (isUrlHistoryEnabled()) {
						addRecentUrl(url);
						updateHistoryControls();
					}

					state = { status: "success", url, svg };
					render();
				} catch (error) {
					if (token !== generationToken) return;
					console.error("QR generation failed:", error);
					state = {
						status: "error",
						message: "Could not generate QR code. Please try again.",
					};
					render();
				}
			};

			const handleSubmit = (event: Event) => {
				event.preventDefault();
				if (state.status === "generating") return;

				if (!isValidUrl(input.value)) {
					state = {
						status: "error",
						message: "Please enter a valid URL.",
					};
					render();
					input.focus();
					input.select();
					return;
				}

				closeHistory();
				const url = normalizeUrl(input.value);
				void generateQr(url);
			};

			const handleDownloadSvg = () => {
				if (state.status !== "success") return;
				const blob = new Blob([state.svg], {
					type: "image/svg+xml;charset=utf-8",
				});
				const url = URL.createObjectURL(blob);
				const slug = fileSlugFromUrl(state.url);
				triggerDownload(`urlx-qr-${slug}.svg`, url);
				window.setTimeout(() => URL.revokeObjectURL(url), 1000);
			};

			const showExportError = (message: string) => {
				errorEl.hidden = false;
				errorEl.textContent = message;
				input.setAttribute("aria-invalid", "false");
				inputShell.setAttribute("aria-invalid", "false");
			};

			const clearExportError = () => {
				if (state.status !== "error") {
					errorEl.hidden = true;
					errorEl.textContent = "";
				}
			};

			const handleDownloadPng = async () => {
				if (state.status !== "success") return;
				const targetUrl = state.url;
				downloadPngButton.disabled = true;
				downloadPngLabel.textContent = "Preparing...";
				clearExportError();
				try {
					const dataUrl = await renderQrPngDataUrl(targetUrl, {
						margin: 1,
						width: 1024,
						color: { dark: "#1d1d1f", light: "#ffffff" },
					});
					const slug = fileSlugFromUrl(targetUrl);
					triggerDownload(`urlx-qr-${slug}.png`, dataUrl);
				} catch {
					showExportError("Could not export PNG. Please try again.");
				} finally {
					downloadPngButton.disabled = false;
					downloadPngLabel.textContent = "Download PNG";
				}
			};

			form.addEventListener("submit", handleSubmit, { signal });
			downloadSvgButton.addEventListener("click", handleDownloadSvg, { signal });
			downloadPngButton.addEventListener("click", handleDownloadPng, { signal });
			rememberHistory.addEventListener(
				"change",
				() => {
					setUrlHistoryEnabled(rememberHistory.checked);
					if (!rememberHistory.checked) {
						clearRecentUrls();
					}
					closeHistory();
					updateHistoryControls();
				},
				{ signal },
			);
			clearHistoryButton.addEventListener("click", () => {
				clearRecentUrls();
				closeHistory();
				updateHistoryControls();
				input.focus();
			}, { signal });
			input.addEventListener("focus", renderHistory, { signal });
			input.addEventListener("input", renderHistory, { signal });
			input.addEventListener("input", updateSubmitState, { signal });
			input.addEventListener(
				"input",
				() => {
					const stripped = stripScheme(input.value);
					if (stripped !== input.value) {
						const start = input.selectionStart;
						const end = input.selectionEnd;
						const removed = input.value.length - stripped.length;
						input.value = stripped;
						if (start !== null && end !== null) {
							input.setSelectionRange(
								Math.max(0, start - removed),
								Math.max(0, end - removed),
							);
						}
					}
				},
				{ signal },
			);
			input.addEventListener("keydown", handleHistoryKeydown, { signal });
			document.addEventListener("mousedown", (event) => {
				if (!inputWrap.contains(event.target as Node)) {
					closeHistory();
				}
			}, { signal });

			updateHistoryControls();
			render();
			signal.addEventListener(
				"abort",
				() => {
					generationToken += 1;
				},
				{ once: true },
			);
		},
	);
</script>
