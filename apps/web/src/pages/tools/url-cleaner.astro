---
import Layout from "../../layouts/Layout.astro";

const title = "URL Cleaner | URLX";
const description =
	"Remove tracking parameters from URLs and copy a cleaner link. Free, private, and no sign-up required.";

const pageUrl = new URL("/tools/url-cleaner", Astro.site).toString();

const softwareSchema = {
	"@context": "https://schema.org",
	"@type": "WebApplication",
	name: "URL Cleaner",
	applicationCategory: "UtilitiesApplication",
	operatingSystem: "Web",
	offers: {
		"@type": "Offer",
		price: "0",
		priceCurrency: "USD",
	},
	url: pageUrl,
};
---

<Layout title={title} description={description}>
	<script is:inline type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />

	<section
		data-page-root="url-cleaner"
		class="flex flex-1 items-center bg-white"
	>
		<div class="mx-auto w-full max-w-[800px] px-6 pt-16 pb-24 text-center sm:pb-28">
			<h1
				class="text-[40px] font-semibold leading-[1.05] tracking-[-0.02em] text-ink sm:text-[56px]"
			>
				Clean tracking from URLs.
			</h1>
			<p
				class="mx-auto mt-5 max-w-[34ch] text-[19px] leading-7 text-ink-2 sm:text-[21px]"
			>
				Strip common tracking parameters and keep the link that matters.
			</p>

			<div class="mx-auto mt-10 max-w-[560px] text-left">
				<form
					class="flex flex-col gap-3"
					data-url-cleaner="form"
					novalidate
				>
					<div class="flex flex-col gap-3 sm:flex-row">
						<label class="sr-only" for="url-cleaner-input">URL to clean</label>
						<div class="relative flex-1" data-url-cleaner="input-wrap">
							<div
								class="field flex w-full items-center gap-2 overflow-hidden pl-4"
								data-url-cleaner="input-shell"
							>
								<span
									class="shrink-0 select-none text-[15px] text-ink-2"
									aria-hidden="true"
								>
									https://
								</span>
								<input
									id="url-cleaner-input"
									name="url"
									type="url"
									inputmode="url"
									autocomplete="off"
									spellcheck="false"
									autocapitalize="off"
									placeholder="example.com?utm_source=email"
									class="min-w-0 flex-1 bg-transparent text-[15px] text-ink placeholder:text-ink-2/70 focus:outline-none"
									data-url-cleaner="url-input"
									role="combobox"
									aria-invalid="false"
									aria-expanded="false"
									aria-autocomplete="list"
									aria-haspopup="listbox"
									aria-controls="url-cleaner-history"
									aria-describedby="url-cleaner-error"
								/>
							</div>
							<ul
								id="url-cleaner-history"
								class="absolute inset-x-0 top-full z-30 mt-2 max-h-[280px] overflow-auto rounded-xl border border-hair bg-white py-1 shadow-[0_8px_30px_rgb(0_0_0/0.08)]"
								role="listbox"
								aria-label="Recent URLs"
								data-url-cleaner="history"
								hidden
							>
							</ul>
						</div>
						<button
							type="submit"
							class="btn w-full sm:w-auto sm:min-w-[148px]"
							data-url-cleaner="submit"
						>
							<span
								class="spinner shrink-0"
								aria-hidden="true"
								data-url-cleaner="submit-spinner"
								hidden
							>
							</span>
							<span data-url-cleaner="submit-label">Clean URL</span>
						</button>
					</div>
					<div
						class="flex flex-col gap-2 text-[13px] leading-5 text-ink-2 sm:flex-row sm:items-center sm:justify-between"
					>
						<label class="inline-flex items-center gap-2">
							<input
								type="checkbox"
								class="h-4 w-4 accent-accent"
								data-url-cleaner="remember-history"
							/>
							<span>Remember recent URLs on this device</span>
						</label>
						<button
							type="button"
							class="self-start text-link underline-offset-2 hover:underline sm:self-auto"
							data-url-cleaner="clear-history"
							hidden
						>
							Clear recent URLs
						</button>
					</div>
				</form>

				<p
					id="url-cleaner-error"
					class="mt-3 text-[14px] leading-5 text-[#d70015]"
					role="alert"
					aria-live="assertive"
					data-url-cleaner="error"
					hidden
				>
				</p>

				<section
					class="surface reveal mt-8 p-6 text-left sm:p-7"
					data-url-cleaner="result"
					aria-labelledby="url-cleaner-result-label"
					aria-live="polite"
					hidden
				>
					<h2
						id="url-cleaner-result-label"
						class="text-[13px] font-semibold uppercase tracking-[0.06em] text-ink-2"
					>
						Cleaned URL
					</h2>

					<div class="mt-3 flex flex-col gap-3 sm:flex-row sm:items-center">
						<a
							href="#"
							class="hover-border flex-1 break-all rounded-xl border border-hair bg-white px-4 py-3 text-[16px] text-link no-underline"
							data-url-cleaner="result-url-link"
							rel="noopener noreferrer"
							target="_blank"
						>
							<span data-url-cleaner="result-url"></span>
						</a>
						<button
							type="button"
							class="btn-secondary inline-flex items-center justify-center gap-2 self-stretch rounded-xl border px-5 py-3 text-[15px]"
							data-url-cleaner="copy"
							aria-label="Copy cleaned URL to clipboard"
						>
							<span class="copy-label" data-url-cleaner="copy-label">Copy</span>
						</button>
					</div>

					<p
						class="mt-4 text-[14px] leading-5 text-ink-2"
						data-url-cleaner="result-meta"
					>
					</p>

					<button
						type="button"
						class="btn-secondary mt-5 inline-flex h-11 items-center justify-center rounded-xl border px-5 text-[15px]"
						data-url-cleaner="reset"
					>
						Clean another URL
					</button>
				</section>
			</div>
		</div>
	</section>
</Layout>

<script>
	import { copyToClipboard } from "../../lib/copy-to-clipboard";
	import { registerPageScript } from "../../lib/page-script";
	import {
		addRecentUrl,
		clearRecentUrls,
		getRecentUrls,
		isUrlHistoryEnabled,
		removeRecentUrl,
		setUrlHistoryEnabled,
	} from "../../lib/url-history";
	import { normalizeUserUrlInput, stripHttpsScheme } from "../../lib/url-tools";
	import { cleanUrl, isCleanableUrl } from "../../lib/url-cleaner";

	type State =
		| { status: "idle" }
		| {
				status: "success";
				cleanedUrl: string;
				removedCount: number;
				removedNames: string[];
		  }
		| { status: "error"; message: string };

	registerPageScript<HTMLElement>(
		'[data-page-root="url-cleaner"]',
		(root, signal) => {
			const selectRequired = <T extends Element>(selector: string): T => {
				const element = root.querySelector<T>(selector);
				if (!element) {
					throw new Error(`Missing required element: ${selector}`);
				}
				return element;
			};

			const form = selectRequired<HTMLFormElement>(
				'[data-url-cleaner="form"]',
			);
			const input = selectRequired<HTMLInputElement>(
				'[data-url-cleaner="url-input"]',
			);
			const inputShell = selectRequired<HTMLElement>(
				'[data-url-cleaner="input-shell"]',
			);
			const inputWrap = selectRequired<HTMLElement>(
				'[data-url-cleaner="input-wrap"]',
			);
			const submitButton = selectRequired<HTMLButtonElement>(
				'[data-url-cleaner="submit"]',
			);
			const submitLabel = selectRequired<HTMLElement>(
				'[data-url-cleaner="submit-label"]',
			);
			const submitSpinner = selectRequired<HTMLElement>(
				'[data-url-cleaner="submit-spinner"]',
			);
			const errorEl = selectRequired<HTMLElement>(
				'[data-url-cleaner="error"]',
			);
			const resultPanel = selectRequired<HTMLElement>(
				'[data-url-cleaner="result"]',
			);
			const resultUrl = selectRequired<HTMLElement>(
				'[data-url-cleaner="result-url"]',
			);
			const resultUrlLink = selectRequired<HTMLAnchorElement>(
				'[data-url-cleaner="result-url-link"]',
			);
			const resultMeta = selectRequired<HTMLElement>(
				'[data-url-cleaner="result-meta"]',
			);
			const copyButton = selectRequired<HTMLButtonElement>(
				'[data-url-cleaner="copy"]',
			);
			const copyLabel = selectRequired<HTMLElement>(
				'[data-url-cleaner="copy-label"]',
			);
			const resetButton = selectRequired<HTMLButtonElement>(
				'[data-url-cleaner="reset"]',
			);
			const historyList = selectRequired<HTMLUListElement>(
				'[data-url-cleaner="history"]',
			);
			const rememberHistory = selectRequired<HTMLInputElement>(
				'[data-url-cleaner="remember-history"]',
			);
			const clearHistoryButton = selectRequired<HTMLButtonElement>(
				'[data-url-cleaner="clear-history"]',
			);

			let state: State = { status: "idle" };
			let copyResetTimer: number | null = null;
			let historyItems: string[] = [];
			let historyActive = -1;

			const closeHistory = () => {
				historyList.hidden = true;
				historyActive = -1;
				input.setAttribute("aria-expanded", "false");
				input.removeAttribute("aria-activedescendant");
			};

			const setHistoryActive = (index: number) => {
				historyActive = index;
				const options = Array.from(historyList.children);
				options.forEach((option, i) => {
					option.setAttribute("aria-selected", i === index ? "true" : "false");
				});
				if (index >= 0 && options[index]) {
					input.setAttribute("aria-activedescendant", options[index].id);
					options[index].scrollIntoView({ block: "nearest" });
				} else {
					input.removeAttribute("aria-activedescendant");
				}
			};

			const applyHistoryUrl = (url: string) => {
				input.value = stripHttpsScheme(url);
				closeHistory();
				input.focus();
				const end = input.value.length;
				input.setSelectionRange(end, end);
				updateSubmitState();
			};

			const updateHistoryControls = () => {
				const enabled = isUrlHistoryEnabled();
				rememberHistory.checked = enabled;
				clearHistoryButton.hidden = !enabled || getRecentUrls().length === 0;
			};

			const buildHistoryOption = (url: string, index: number) => {
				const option = document.createElement("li");
				option.id = `url-cleaner-history-opt-${index}`;
				option.setAttribute("role", "option");
				option.setAttribute("aria-selected", "false");
				option.className =
					"group flex cursor-pointer items-center gap-2 px-3 py-2 text-[15px] text-ink aria-selected:bg-surface hover:bg-surface";

				const label = document.createElement("span");
				label.className = "flex-1 truncate";
				label.title = url;
				label.textContent = url;
				option.appendChild(label);

				const remove = document.createElement("button");
				remove.type = "button";
				remove.tabIndex = -1;
				remove.className =
					"shrink-0 rounded-md p-1 text-ink-2 opacity-0 transition group-hover:opacity-100 hover:bg-hair/50 hover:text-ink";
				remove.setAttribute("aria-label", `Remove ${url} from recent`);
				remove.innerHTML =
					'<svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M4 4 12 12M12 4 4 12"/></svg>';
				remove.addEventListener("mousedown", (event) => {
					event.preventDefault();
					event.stopPropagation();
				});
				remove.addEventListener("click", (event) => {
					event.preventDefault();
					event.stopPropagation();
					removeRecentUrl(url);
					renderHistory();
					updateHistoryControls();
					input.focus();
				});
				option.appendChild(remove);

				option.addEventListener("mousedown", (event) => event.preventDefault());
				option.addEventListener("click", () => applyHistoryUrl(url));
				option.addEventListener("mousemove", () => setHistoryActive(index));
				return option;
			};

			function renderHistory() {
				if (!isUrlHistoryEnabled()) {
					closeHistory();
					updateHistoryControls();
					return;
				}

				const query = input.value.trim().toLowerCase();
				historyItems = getRecentUrls().filter((url) => {
					const lower = url.toLowerCase();
					return query === "" ? true : lower.includes(query) && lower !== query;
				});
				historyList.replaceChildren();
				historyActive = -1;
				input.removeAttribute("aria-activedescendant");
				if (historyItems.length === 0) {
					closeHistory();
					updateHistoryControls();
					return;
				}
				historyItems.forEach((url, index) => {
					historyList.appendChild(buildHistoryOption(url, index));
				});
				historyList.hidden = false;
				input.setAttribute("aria-expanded", "true");
				updateHistoryControls();
			}

			const handleHistoryKeydown = (event: KeyboardEvent) => {
				const open = !historyList.hidden;
				if (event.key === "ArrowDown") {
					if (!open) {
						renderHistory();
						if (!historyList.hidden) setHistoryActive(0);
					} else {
						setHistoryActive(Math.min(historyActive + 1, historyItems.length - 1));
					}
					if (!historyList.hidden) event.preventDefault();
				} else if (event.key === "ArrowUp") {
					if (open) {
						setHistoryActive(historyActive <= 0 ? -1 : historyActive - 1);
						event.preventDefault();
					}
				} else if (event.key === "Enter") {
					if (open && historyActive >= 0) {
						event.preventDefault();
						applyHistoryUrl(historyItems[historyActive]);
					}
				} else if (event.key === "Escape") {
					if (open) {
						event.preventDefault();
						closeHistory();
					}
				}
			};

			const updateSubmitState = () => {
				submitButton.disabled = !isCleanableUrl(input.value);
			};

			const resetCopyLabel = () => {
				if (copyResetTimer !== null) {
					window.clearTimeout(copyResetTimer);
					copyResetTimer = null;
				}
				copyLabel.textContent = "Copy";
				copyLabel.removeAttribute("data-swapping");
			};

			const swapCopyLabel = (next: string) => {
				copyLabel.setAttribute("data-swapping", "true");
				window.setTimeout(() => {
					copyLabel.textContent = next;
					copyLabel.removeAttribute("data-swapping");
				}, 140);
			};

			const formatRemovedNames = (names: string[]): string => {
				if (names.length === 0) return "";
				if (names.length === 1) return names[0];
				return `${names.slice(0, -1).join(", ")} and ${names[names.length - 1]}`;
			};

			const render = () => {
				updateSubmitState();
				submitLabel.textContent = "Clean URL";
				submitSpinner.hidden = true;

				if (state.status === "error") {
					errorEl.hidden = false;
					errorEl.textContent = state.message;
					input.setAttribute("aria-invalid", "true");
					inputShell.setAttribute("aria-invalid", "true");
				} else {
					errorEl.hidden = true;
					errorEl.textContent = "";
					input.setAttribute("aria-invalid", "false");
					inputShell.setAttribute("aria-invalid", "false");
				}

				if (state.status === "success") {
					resultUrl.textContent = state.cleanedUrl;
					resultUrlLink.setAttribute("href", state.cleanedUrl);
					resultUrlLink.setAttribute("title", state.cleanedUrl);

					if (state.removedCount === 0) {
						resultMeta.textContent =
							"No tracking parameters found. Your link is already clean.";
					} else {
						const names = formatRemovedNames(state.removedNames);
						resultMeta.textContent = `Removed ${state.removedCount} parameter${state.removedCount === 1 ? "" : "s"}: ${names}.`;
					}

					resultPanel.hidden = false;
					resetCopyLabel();
				} else {
					resultPanel.hidden = true;
					resetCopyLabel();
				}
			};

			const handleSubmit = (event: Event) => {
				event.preventDefault();
				closeHistory();
				if (!isCleanableUrl(input.value)) {
					state = {
						status: "error",
						message: "Please enter a valid URL.",
					};
					render();
					input.focus();
					input.select();
					return;
				}

				const result = cleanUrl(input.value);
				if (!result.ok) {
					state = { status: "error", message: result.error };
					render();
					input.focus();
					input.select();
					return;
				}

				const normalizedUrl = normalizeUserUrlInput(input.value);
				if (normalizedUrl && isUrlHistoryEnabled()) {
					addRecentUrl(normalizedUrl);
					updateHistoryControls();
				}

				state = {
					status: "success",
					cleanedUrl: result.cleanedUrl,
					removedCount: result.removedCount,
					removedNames: result.removedNames,
				};
				render();
				copyButton.focus();
			};

			const handleCopy = async () => {
				if (state.status !== "success") return;
				const ok = await copyToClipboard(state.cleanedUrl);
				if (!ok) return;
				swapCopyLabel("Copied");
				if (copyResetTimer !== null) {
					window.clearTimeout(copyResetTimer);
				}
				copyResetTimer = window.setTimeout(() => {
					swapCopyLabel("Copy");
					copyResetTimer = null;
				}, 1600);
			};

			const handleReset = () => {
				state = { status: "idle" };
				input.value = "";
				render();
				input.focus();
			};

			form.addEventListener("submit", handleSubmit, { signal });
			copyButton.addEventListener("click", handleCopy, { signal });
			resetButton.addEventListener("click", handleReset, { signal });
			rememberHistory.addEventListener(
				"change",
				() => {
					setUrlHistoryEnabled(rememberHistory.checked);
					if (!rememberHistory.checked) {
						clearRecentUrls();
					}
					closeHistory();
					updateHistoryControls();
				},
				{ signal },
			);
			clearHistoryButton.addEventListener("click", () => {
				clearRecentUrls();
				closeHistory();
				updateHistoryControls();
				input.focus();
			}, { signal });
			input.addEventListener("focus", renderHistory, { signal });
			input.addEventListener("input", renderHistory, { signal });
			input.addEventListener("input", updateSubmitState, { signal });
			input.addEventListener(
				"input",
				() => {
					const stripped = stripHttpsScheme(input.value);
					if (stripped !== input.value) {
						const start = input.selectionStart;
						const end = input.selectionEnd;
						const removed = input.value.length - stripped.length;
						input.value = stripped;
						if (start !== null && end !== null) {
							input.setSelectionRange(
								Math.max(0, start - removed),
								Math.max(0, end - removed),
							);
						}
					}
				},
				{ signal },
			);
			input.addEventListener("keydown", handleHistoryKeydown, { signal });
			document.addEventListener("mousedown", (event) => {
				if (!inputWrap.contains(event.target as Node)) {
					closeHistory();
				}
			}, { signal });

			updateHistoryControls();
			render();
			signal.addEventListener(
				"abort",
				() => {
					if (copyResetTimer !== null) {
						window.clearTimeout(copyResetTimer);
					}
				},
				{ once: true },
			);
		},
	);
</script>
