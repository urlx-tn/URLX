---
import ConversionTool from "../../components/ConversionTool.astro";
import Layout from "../../layouts/Layout.astro";

const title = "URL to Markdown Converter | URLX";
const description =
	"Convert a public webpage into clean Markdown. Free, fast, and no sign-up required.";
const pageUrl = new URL("/tools/url-to-markdown", Astro.site).toString();
const softwareSchema = {
	"@context": "https://schema.org",
	"@type": "WebApplication",
	name: "URL to Markdown Converter",
	applicationCategory: "UtilitiesApplication",
	operatingSystem: "Web",
	offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
	url: pageUrl,
};
---

<Layout title={title} description={description}>
	<script is:inline type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
	<ConversionTool
		format="markdown"
		heading="Convert a URL to Markdown."
		intro="Extract readable content from a public webpage as clean Markdown."
		resultLabel="Markdown"
		downloadLabel="Download .md"
		privacyText="The submitted page is fetched through Cloudflare for conversion. URLX does not store the generated Markdown."
	/>
</Layout>
