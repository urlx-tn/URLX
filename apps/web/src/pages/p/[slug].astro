---
import QRCode from "qrcode/lib/browser.js";

import StatusPage from "../../components/StatusPage.astro";
import Layout from "../../layouts/Layout.astro";
import { orpc } from "../../lib/orpc";
import { isOrpcErrorCode } from "../../lib/orpc-errors";

const { slug } = Astro.params;

type BioPage = Awaited<ReturnType<typeof orpc.bio.getBySlug>>;

let page: BioPage | null = null;

if (slug) {
	try {
		page = await orpc.bio.getBySlug({ slug });
	} catch (error) {
		if (!isOrpcErrorCode(error, "PAGE_NOT_FOUND")) {
			throw error;
		}
	}
}

if (!page) {
	Astro.response.status = 404;
}

const title = page ? `${page.title} | URLX` : "Page not found | URLX";
const description =
	page?.description ?? "A collection of links shared on URLX.";

function canFetchFavicon(host: string) {
	const labels = host.split(".");
	const tld = labels.at(-1) ?? "";
	return (
		labels.length > 1 && (/^[a-z]{2,}$/i.test(tld) || tld.startsWith("xn--"))
	);
}

const links = (page?.links ?? []).map((link) => {
	let host = "";
	try {
		host = new URL(link.url).hostname.replace(/^www\./, "");
	} catch {
		host = "";
	}

	return {
		label: link.label,
		url: link.url,
		host,
		favicon: canFetchFavicon(host)
			? `/api/favicon?host=${encodeURIComponent(host)}`
			: null,
	};
});

const initials = page
	? page.title
			.trim()
			.split(/\s+/)
			.slice(0, 2)
			.map((word) => word.charAt(0).toUpperCase())
			.join("") || "•"
	: "";

// Deterministic accent hue per page so each one feels distinct without going
// off-brand — kept on the blue-ish side of the wheel.
function hueFromString(value: string) {
	let hash = 0;
	for (const char of value) {
		hash = (hash * 31 + char.charCodeAt(0)) % 360;
	}
	return hash;
}

const hue = page ? hueFromString(page.slug) : 210;
const avatarStyle = `background-color: hsl(${hue} 64% 52%)`;
const glowStyle = `background: radial-gradient(60% 70% at 50% 0%, hsl(${hue} 85% 60% / 0.18), transparent 72%)`;
const pageUrl = new URL(Astro.url.pathname, Astro.url.origin).toString();
const qrColor = { dark: "#1d1d1f", light: "#ffffff" };
const qrSvg = page
	? await QRCode.toString(pageUrl, {
			type: "svg",
			errorCorrectionLevel: "M",
			margin: 1,
			color: qrColor,
		})
	: "";
---

<Layout
	title={title}
	description={description}
	robots={page ? undefined : "noindex, follow"}
	chrome={false}
>
	{
		page ? (
			<section
				data-page-root="bio-page"
				class="relative isolate flex flex-1 flex-col items-center overflow-hidden bg-white px-5 pb-16 pt-14 sm:pt-20"
			>
				<div
					class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-96"
					style={glowStyle}
				/>

				<div class="reveal relative flex w-full max-w-[480px] flex-1 flex-col">
					<button
						type="button"
						data-qr-open
						class="absolute right-0 top-0 z-10 inline-flex h-9 items-center gap-1.5 rounded-full border border-hair bg-white pl-2.5 pr-3 text-[13px] font-medium text-ink-2 shadow-sm transition hover:border-accent/60 hover:text-ink"
						aria-label="Show QR code for this page"
						aria-haspopup="dialog"
					>
						<svg
							viewBox="0 0 24 24"
							class="size-[17px]"
							fill="none"
							stroke="currentColor"
							stroke-width="1.7"
							stroke-linecap="round"
							stroke-linejoin="round"
							aria-hidden="true"
						>
							<rect x="3" y="3" width="7" height="7" rx="1.5" />
							<rect x="14" y="3" width="7" height="7" rx="1.5" />
							<rect x="3" y="14" width="7" height="7" rx="1.5" />
							<path d="M14 14h3v3M21 14v3M14 21h3M21 21h.01" />
						</svg>
						QR
					</button>

					<header class="flex flex-col items-center text-center">
						<div
							class="flex size-24 items-center justify-center rounded-full text-[34px] font-semibold text-white shadow-[0_12px_34px_rgb(0_0_0/0.16)] ring-4 ring-white"
							style={avatarStyle}
						>
							{initials}
						</div>
						<h1 class="mt-5 text-[27px] font-semibold tracking-[-0.02em] text-ink sm:text-[31px]">
							{page.title}
						</h1>
						<p class="mt-1 text-[14px] font-medium text-ink-2">@{page.slug}</p>
						{page.description && (
							<p class="mt-3 max-w-[42ch] text-[15px] leading-7 text-ink-2">
								{page.description}
							</p>
						)}
					</header>

					<ul class="mt-9 flex flex-col gap-3">
						{links.map((link, index) => (
							<li>
								<a
									href={link.url}
									target="_blank"
									rel="noopener noreferrer nofollow"
									class="group flex items-center gap-3 rounded-2xl border border-hair bg-white px-3.5 py-3.5 no-underline shadow-[0_1px_2px_rgb(0_0_0/0.04)] transition hover:border-accent/60"
								>
									<span class="relative grid size-10 shrink-0 place-items-center overflow-hidden rounded-xl bg-surface text-ink-2 ring-1 ring-black/5">
										<svg
											viewBox="0 0 24 24"
											class="size-[18px]"
											fill="none"
											stroke="currentColor"
											stroke-width="1.5"
											aria-hidden="true"
										>
											<circle cx="12" cy="12" r="9" />
											<path d="M3 12h18M12 3c2.6 2.7 2.6 15.3 0 18M12 3c-2.6 2.7-2.6 15.3 0 18" />
										</svg>
										<span class="absolute inset-0 grid place-items-center bg-white text-[13px] font-semibold uppercase text-ink-2">
											{link.host.charAt(0) || "#"}
										</span>
										{link.favicon ? (
											<img
												src={link.favicon}
												alt=""
												width="40"
												height="40"
												loading={index < 6 ? "eager" : "lazy"}
												decoding="async"
												referrerpolicy="no-referrer"
												data-favicon
												hidden
												class="absolute inset-0 size-full object-cover"
											/>
										) : null}
									</span>
									<span class="min-w-0 flex-1 truncate text-center text-[15px] font-semibold text-ink">
										{link.label}
									</span>
									<span
										class="grid size-10 shrink-0 place-items-center text-ink-2/45 transition group-hover:translate-x-0.5 group-hover:text-ink-2"
										aria-hidden="true"
									>
										<svg
											viewBox="0 0 24 24"
											class="size-[18px]"
											fill="none"
											stroke="currentColor"
											stroke-width="1.7"
											stroke-linecap="round"
											stroke-linejoin="round"
										>
											<path d="M7 17 17 7M9 7h8v8" />
										</svg>
									</span>
								</a>
							</li>
						))}
					</ul>

					<footer class="mt-auto pt-14 text-center">
						<a
							href="/tools/link-in-bio"
							class="inline-flex items-center gap-1.5 rounded-full border border-hair bg-white/80 px-4 py-2 text-[13px] font-medium text-ink-2 no-underline shadow-sm backdrop-blur transition hover:border-accent/60 hover:text-ink"
						>
							<img
								src="/favicons/favicon-32x32.png"
								alt=""
								width="16"
								height="16"
								class="size-4 rounded-[4px]"
							/>
							<span>
								Create your own with{" "}
								<span class="font-semibold text-ink">URLX</span>
							</span>
						</a>
					</footer>
				</div>

				<div
					class="fixed inset-0 z-50 grid place-items-center bg-ink/40 px-5 backdrop-blur-sm"
					data-qr-modal
					role="dialog"
					aria-modal="true"
					aria-label="QR code for this page"
					hidden
				>
					<div class="reveal w-full max-w-[340px] rounded-2xl bg-white p-6 shadow-[0_24px_60px_rgb(0_0_0/0.24)]">
						<div class="flex items-center justify-between">
							<h2 class="text-[15px] font-semibold text-ink">QR code</h2>
							<button
								type="button"
								data-qr-close
								class="grid size-8 place-items-center rounded-full text-ink-2 transition hover:bg-surface hover:text-ink"
								aria-label="Close"
							>
								<svg
									viewBox="0 0 24 24"
									class="size-[18px]"
									fill="none"
									stroke="currentColor"
									stroke-width="1.7"
									stroke-linecap="round"
								>
									<path d="M6 6 18 18M18 6 6 18" />
								</svg>
							</button>
						</div>

						<div
							class="mx-auto mt-4 grid h-[232px] w-[232px] place-items-center rounded-xl border border-hair bg-white p-3"
							data-qr-canvas
							role="img"
							aria-label="QR code"
						/>

						<p
							class="mt-3 break-all text-center text-[13px] leading-5 text-ink-2"
							data-qr-url
						/>

						<div class="mt-4 flex gap-2.5" data-qr-actions hidden>
							<button
								type="button"
								class="btn-secondary inline-flex h-10 flex-1 items-center justify-center rounded-xl border px-4 text-[14px] font-medium"
								data-qr-svg
							>
								SVG
							</button>
							<button
								type="button"
								class="btn-secondary inline-flex h-10 flex-1 items-center justify-center rounded-xl border px-4 text-[14px] font-medium"
								data-qr-png
							>
								<span data-qr-png-label>PNG</span>
							</button>
						</div>

						<p
							class="mt-3 text-center text-[13px] leading-5 text-ink-2"
							data-qr-status
							aria-live="polite"
						/>
					</div>
				</div>
				<script
					is:inline
					type="application/json"
					data-qr-data
					set:html={JSON.stringify({ pageUrl, qrSvg })}
				></script>
			</section>
			) : (
				<StatusPage
					code="404"
					title="Page not found"
					description="This link page doesn’t exist or has been removed."
					primaryHref="/tools/link-in-bio"
					primaryLabel="Create a page"
					secondaryHref="/"
					secondaryLabel="Return home"
				/>
			)
		}
</Layout>

<script>
	import { registerPageScript } from "../../lib/page-script";

	// Reveal the local placeholder behind a favicon that fails to load.
	registerPageScript<HTMLElement>('[data-page-root="bio-page"]', (root, signal) => {
		const favicons = root.querySelectorAll<HTMLImageElement>("img[data-favicon]");
		for (const img of favicons) {
			const showFavicon = () => {
				img.hidden = false;
			};

			const showFallback = () => {
				window.clearTimeout(fallbackTimer);
				img.remove();
			};

			const fallbackTimer = window.setTimeout(showFallback, 4000);
			const handleLoad = () => {
				window.clearTimeout(fallbackTimer);
				if (img.naturalWidth > 0 && img.naturalHeight > 0) {
					showFavicon();
				} else {
					showFallback();
				}
			};

			img.addEventListener("error", showFallback, { once: true, signal });
			img.addEventListener("load", handleLoad, { once: true, signal });
			signal.addEventListener(
				"abort",
				() => window.clearTimeout(fallbackTimer),
				{ once: true },
			);
			if (img.complete && img.naturalWidth === 0) {
				showFallback();
			} else if (img.complete) {
				handleLoad();
			}
		}

		const qrDataEl = root.querySelector<HTMLScriptElement>("[data-qr-data]");
		const qrData = qrDataEl
			? (JSON.parse(qrDataEl.textContent ?? "{}") as {
					pageUrl?: string;
					qrSvg?: string;
				})
			: {};
		const pageUrl = qrData.pageUrl ?? window.location.href;
		const qrSvg = qrData.qrSvg ?? "";

		const openButton = root.querySelector<HTMLButtonElement>("[data-qr-open]");
		const modal = root.querySelector<HTMLElement>("[data-qr-modal]");
		const closeButton = root.querySelector<HTMLButtonElement>("[data-qr-close]");
		const canvas = root.querySelector<HTMLElement>("[data-qr-canvas]");
		const urlEl = root.querySelector<HTMLElement>("[data-qr-url]");
		const actions = root.querySelector<HTMLElement>("[data-qr-actions]");
		const svgButton = root.querySelector<HTMLButtonElement>("[data-qr-svg]");
		const pngButton = root.querySelector<HTMLButtonElement>("[data-qr-png]");
		const pngLabel = root.querySelector<HTMLElement>("[data-qr-png-label]");
		const statusEl = root.querySelector<HTMLElement>("[data-qr-status]");

		if (
			!openButton ||
			!modal ||
			!closeButton ||
			!canvas ||
			!urlEl ||
			!actions ||
			!svgButton ||
			!pngButton ||
			!pngLabel ||
			!statusEl
		) {
			return;
		}

		const fileSlug = window.location.pathname.split("/").pop() || "page";
		let currentSvg: string | null = null;
		let generated = false;

		const triggerDownload = (filename: string, href: string) => {
			const anchor = document.createElement("a");
			anchor.href = href;
			anchor.download = filename;
			document.body.appendChild(anchor);
			anchor.click();
			anchor.remove();
		};

		const svgToPngDataUrl = (svg: string) =>
			new Promise<string>((resolve, reject) => {
				const blob = new Blob([svg], { type: "image/svg+xml;charset=utf-8" });
				const imageUrl = URL.createObjectURL(blob);
				const image = new Image();
				image.width = 1024;
				image.height = 1024;
				image.addEventListener(
					"load",
					() => {
						try {
							const canvas = document.createElement("canvas");
							canvas.width = 1024;
							canvas.height = 1024;
							const context = canvas.getContext("2d");
							if (!context) {
								reject(new Error("Canvas is not available."));
								return;
							}
							context.fillStyle = "#ffffff";
							context.fillRect(0, 0, canvas.width, canvas.height);
							context.drawImage(image, 0, 0, canvas.width, canvas.height);
							resolve(canvas.toDataURL("image/png"));
						} catch (error) {
							reject(error);
						} finally {
							URL.revokeObjectURL(imageUrl);
						}
					},
					{ once: true },
				);
				image.addEventListener(
					"error",
					() => {
						URL.revokeObjectURL(imageUrl);
						reject(new Error("Could not load QR SVG."));
					},
					{ once: true },
				);
				image.src = imageUrl;
			});

		const generate = async () => {
			if (generated) return;
			generated = true;
			try {
				currentSvg = qrSvg;
				canvas.innerHTML = qrSvg;
				const svgEl = canvas.querySelector("svg");
				if (svgEl) {
					svgEl.setAttribute("width", "100%");
					svgEl.setAttribute("height", "100%");
					svgEl.setAttribute("aria-label", `QR code for ${pageUrl}`);
				}
				actions.hidden = false;
				statusEl.textContent = "";
			} catch {
				generated = false;
				statusEl.textContent = "Could not generate QR code. Try again.";
			}
		};

		const openModal = () => {
			modal.hidden = false;
			urlEl.textContent = pageUrl;
			closeButton.focus();
			void generate();
		};

		const closeModal = () => {
			modal.hidden = true;
			openButton.focus();
		};

		openButton.addEventListener("click", openModal, { signal });
		closeButton.addEventListener("click", closeModal, { signal });
		modal.addEventListener("click", (event) => {
			if (event.target === modal) closeModal();
		}, { signal });
		document.addEventListener("keydown", (event) => {
			if (event.key === "Escape" && !modal.hidden) closeModal();
		}, { signal });

		svgButton.addEventListener("click", () => {
			if (!currentSvg) return;
			const blob = new Blob([currentSvg], {
				type: "image/svg+xml;charset=utf-8",
			});
			const href = URL.createObjectURL(blob);
			triggerDownload(`urlx-qr-${fileSlug}.svg`, href);
			window.setTimeout(() => URL.revokeObjectURL(href), 1000);
		}, { signal });

		pngButton.addEventListener("click", async () => {
			if (!currentSvg) return;
			pngButton.disabled = true;
			pngLabel.textContent = "...";
			try {
				const dataUrl = await svgToPngDataUrl(currentSvg);
				triggerDownload(`urlx-qr-${fileSlug}.png`, dataUrl);
			} catch {
				statusEl.textContent = "Could not export PNG. Try again.";
			} finally {
				pngButton.disabled = false;
				pngLabel.textContent = "PNG";
			}
		}, { signal });
	});
</script>
