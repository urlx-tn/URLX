---
import { ClientRouter, fade } from "astro:transitions";
import LoadingIndicator from "astro-loading-indicator/component";
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	imageAlt?: string;
	canonicalPath?: string;
	robots?: string;
	chrome?: boolean;
}

const {
	title = "Free URL Tools | URLX",
	description = "Free, open-source URL tools for shortening links, cleaning tracking parameters, converting webpages to Markdown, creating QR codes, and building link-in-bio pages.",
	image = "/og-image.png",
	imageAlt = "URLX free and open-source URL tools.",
	canonicalPath,
	robots,
	chrome = true,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const canonical = new URL(
	canonicalPath ?? Astro.url.pathname,
	siteUrl || Astro.url,
).toString();
const ogImage = image.startsWith("http") ? image : `${siteUrl}${image}`;

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: "URLX",
	url: siteUrl || "/",
	description,
};

const organizationSchema = {
	"@context": "https://schema.org",
	"@type": "Organization",
	name: "URLX",
	url: siteUrl || "/",
	logo: `${siteUrl}/favicons/android-chrome-512x512.png`,
	sameAs: ["https://github.com/urlx-tn/URLX"],
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="color-scheme" content="light" />
		<meta name="theme-color" content="#0071e3" />
		<meta name="apple-mobile-web-app-title" content="URLX" />
		<meta name="application-name" content="URLX" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		{robots && <meta name="robots" content={robots} />}
		<link rel="canonical" href={canonical} />

		<link rel="icon" href="/favicons/favicon.ico" sizes="any" />
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicons/favicon-32x32.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href="/favicons/favicon-16x16.png"
		/>
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href="/favicons/apple-touch-icon.png"
		/>
		<link rel="manifest" href="/favicons/site.webmanifest" />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="URLX" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={imageAlt} />
		<meta property="og:locale" content="en_US" />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<meta name="twitter:image:alt" content={imageAlt} />

		<title>{title}</title>

		<script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
		<ClientRouter />
		<LoadingIndicator
			color="var(--color-accent)"
			height="3px"
			animationDuration={240}
			threshold={false}
		/>
	</head>
	<body class="flex min-h-[100dvh] flex-col antialiased">
		{chrome && <Header />}
		<main
			class="flex flex-1 flex-col"
			transition:animate={fade({ duration: "0.2s" })}
		>
			<slot />
		</main>
		{chrome && <Footer />}
	</body>
</html>
