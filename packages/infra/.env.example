# Alchemy infrastructure environment
# These values are read by packages/infra/alchemy.run.ts when running `alchemy dev`
# or `alchemy deploy` from the packages/infra directory.

# Required: origin of the web app, bound to the server Worker as CORS_ORIGIN.
CORS_ORIGIN=http://localhost:4321

# Optional: public origin used when building short links, bound to the server Worker.
# Defaults to http://localhost:3000 if not set.
SHORT_URL_BASE=http://localhost:3000
