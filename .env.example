# URLX local development environment
# Copy this file to `.env` and adjust values for your setup.
# This file is loaded by the cloudflare-local shim in packages/env/src/cloudflare-local.ts.

# Required: origin of the web app, used by the server Worker CORS policy.
CORS_ORIGIN=http://localhost:4321

# Optional: public origin used when building short links.
# Defaults to http://localhost:4321 if not set.
SHORT_URL_BASE=http://localhost:4321

# Required: public URL of the oRPC server, used by the Astro web app.
PUBLIC_SERVER_URL=http://localhost:3000

# Optional: URL of a manually managed conversion Worker when running Astro
# without Alchemy. The full `pnpm run dev` and deployed environments receive
# this URL automatically from Alchemy.
# PUBLIC_CONVERSION_SERVER_URL=https://your-conversion-worker.workers.dev

# Optional: set to `true` to skip runtime validation of public env vars.
# SKIP_ENV_VALIDATION=true
